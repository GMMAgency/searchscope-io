---
import BaseLayout from './BaseLayout.astro';
import CTABand from '../components/CTABand.astro';
import { SITE, GMM } from '../consts';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  tags: string[];
  readingTime: number;
  slug: string;
}
const { title, description, pubDate, updatedDate, author, tags, readingTime, slug } = Astro.props;

const url = new URL(`/blog/${slug}/`, SITE.url).href;
const fmt = new Intl.DateTimeFormat('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: { '@type': 'Person', name: author },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
  },
  keywords: tags.join(', '),
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  image: new URL(SITE.ogImage, SITE.url).href,
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Blog', item: new URL('/blog/', SITE.url).href },
    { '@type': 'ListItem', position: 2, name: title, item: url },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  headerTheme="cream"
  jsonLd={[articleLd, breadcrumbLd]}
>
  <article class="post theme-cream">
    <div class="container">
      <header class="post__head">
        <nav class="post__crumbs" aria-label="Breadcrumb">
          <a href="/blog" class="post__crumb">Blog</a>
          <span aria-hidden="true">/</span>
          <span class="post__crumb post__crumb--current">{tags[0]}</span>
        </nav>
        <div class="post__tags">
          {tags.map((t) => <span class="pill pill--accent">{t}</span>)}
        </div>
        <h1 class="post__title">{title}</h1>
        <p class="post__desc">{description}</p>
        <div class="post__meta mono">
          <span>{author}</span>
          <span aria-hidden="true">·</span>
          <time datetime={pubDate.toISOString()}>{fmt.format(pubDate)}</time>
          <span aria-hidden="true">·</span>
          <span>{readingTime} min read</span>
        </div>
      </header>

      <div class="post__body prose">
        <slot />
      </div>

      <footer class="post__foot">
        <a href={GMM.url} class="post__author-card" target="_blank" rel="noopener">
          <span class="post__author-label mono">Written by</span>
          <span class="post__author-name">{author} · Growth Minded Marketing ↗</span>
          <span class="post__author-blurb">
            We build Searchscope and run it on real client sites every day. If your search picture
            needs reading, that's what we do.
          </span>
        </a>
      </footer>
    </div>
  </article>

  <CTABand
    theme="dark"
    eyebrow="Blog"
    title="Want this read on your own site?"
    sub="Everything we write here, we do for clients. Join the pilot programme and we'll point the co-pilot at your search picture."
  />
</BaseLayout>

<style>
  .post {
    background: var(--surface);
    color: var(--ink);
    padding-block: clamp(2rem, 1.5rem + 4vw, 4.5rem) clamp(3rem, 2rem + 4vw, 5rem);
  }
  .post .container {
    max-width: 720px;
  }

  .post__crumbs {
    display: flex;
    gap: 0.5em;
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--ink-faint);
    margin-bottom: var(--space-l);
  }
  .post__crumb {
    color: var(--ink-dim);
  }
  .post__crumb--current {
    color: var(--accent-deep);
  }
  .post__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: var(--space-m);
  }
  .post__title {
    font-size: var(--step-5);
    line-height: 1.05;
    letter-spacing: -0.03em;
  }
  .post__desc {
    margin-top: var(--space-m);
    font-size: var(--step-2);
    line-height: 1.45;
    color: var(--ink-dim);
    font-family: var(--font-accent);
    font-style: italic;
  }
  :global(html[data-skin='mono']) .post__desc {
    font-style: normal;
    font-size: var(--step-1);
  }
  .post__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6em;
    align-items: center;
    margin-top: var(--space-l);
    padding-top: var(--space-m);
    border-top: 1px solid var(--hairline);
    font-size: var(--step--1);
    color: var(--ink-dim);
  }

  /* ---------- PROSE ---------- */
  .prose {
    margin-top: var(--space-2xl);
  }
  .prose :global(p),
  .prose :global(ul),
  .prose :global(ol) {
    font-size: var(--step-1);
    line-height: 1.7;
    color: var(--ink-dim);
    margin-bottom: var(--space-m);
  }
  .prose :global(p strong),
  .prose :global(li strong) {
    color: var(--ink);
    font-weight: 600;
  }
  .prose :global(em) {
    font-style: italic;
  }
  .prose :global(h2) {
    font-size: var(--step-3);
    line-height: 1.1;
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-s);
    scroll-margin-top: 6rem;
  }
  .prose :global(h3) {
    font-size: var(--step-2);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-xs);
  }
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.4em;
  }
  .prose :global(li) {
    margin-bottom: 0.5em;
  }
  .prose :global(li::marker) {
    color: var(--accent-deep);
  }
  .prose :global(a) {
    color: var(--accent-deep);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--accent) 40%, transparent);
    text-underline-offset: 3px;
    transition: text-decoration-color var(--dur) var(--ease-out);
  }
  .prose :global(a:hover) {
    text-decoration-color: var(--accent);
  }
  .prose :global(blockquote) {
    margin: var(--space-l) 0;
    padding: var(--space-s) var(--space-l);
    border-left: 3px solid var(--accent);
    font-family: var(--font-accent);
    font-style: italic;
    font-size: var(--step-2);
    color: var(--ink);
  }
  .prose :global(blockquote p) {
    color: var(--ink);
    margin-bottom: 0;
  }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: var(--surface-panel);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-xs);
    padding: 0.12em 0.4em;
  }
  .prose :global(pre) {
    margin: var(--space-l) 0;
    padding: var(--space-m);
    border-radius: var(--radius-m);
    border: 1px solid var(--hairline);
    overflow-x: auto;
    font-size: var(--step--1);
    line-height: 1.6;
  }
  .prose :global(pre code) {
    background: none;
    border: 0;
    padding: 0;
    font-size: inherit;
  }
  .prose :global(hr) {
    border: 0;
    height: 1px;
    background: var(--hairline);
    margin: var(--space-xl) 0;
  }
  .prose :global(img) {
    border-radius: var(--radius-m);
    border: 1px solid var(--hairline);
    margin: var(--space-l) 0;
  }

  /* ---------- AUTHOR CARD ---------- */
  .post__foot {
    margin-top: var(--space-2xl);
    padding-top: var(--space-l);
    border-top: 1px solid var(--hairline);
  }
  .post__author-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: var(--space-l);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-m);
    background: var(--surface-panel);
    transition: border-color var(--dur) var(--ease-out);
  }
  .post__author-card:hover {
    border-color: color-mix(in oklab, var(--accent) 45%, var(--hairline));
  }
  .post__author-label {
    font-size: var(--step--2);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .post__author-name {
    font-family: var(--font-heading);
    font-weight: var(--wt-heading);
    font-size: var(--step-1);
    color: var(--ink);
  }
  .post__author-blurb {
    color: var(--ink-dim);
    font-size: var(--step-0);
    line-height: 1.5;
  }
</style>
