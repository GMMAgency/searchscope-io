    .reports .rp-flag.done { animation: none; opacity: 1; }
  }
  @media (max-width: 860px) {
    .reports .probs { grid-template-columns: 1fr; }
    .reports .two { grid-template-columns: 1fr; gap: 28px; }
  }
  @media (max-width: 760px) {
    .reports .rp-comp { grid-template-columns: 1fr; }
    .reports .rp-rail { border-right: none; border-bottom: 1px solid var(--border); }
    .reports .rp-paper { max-width: none; }
  }
  @media (max-width: 640px) {
    .reports { padding: 8px 14px 56px; }
    .reports .rp-hero { padding: 44px 8px 30px; }
