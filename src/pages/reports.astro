  .reports .creamsec { background: var(--cream); border-radius: 18px; padding: 54px 44px; margin-top: 96px; }
  .reports .probs { margin-top: 34px; display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; }
  .reports .prob { border: 1px solid var(--border); border-radius: 14px; background: var(--surface); padding: 18px 18px 16px; }
  .reports .prob .pn { font-family: var(--font-mono); font-size: 9.5px; letter-spacing: 0.09em; text-transform: uppercase; color: var(--faint); }
  .reports .prob h3 { margin: 9px 0 6px; font-size: 15.5px; font-weight: 565; letter-spacing: -0.015em; }
