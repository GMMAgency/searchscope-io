  .reports .pq { margin: 84px auto 0; max-width: 42ch; text-align: center; font-size: 23px; line-height: 1.42; letter-spacing: -0.02em; font-weight: 545; }
  .reports .pq .cite { display: block; margin-top: 16px; font-family: var(--font-mono); font-size: 9.5px; font-weight: 500; letter-spacing: 0.13em; text-transform: uppercase; color: var(--faint); }
  .reports .two { display: grid; grid-template-columns: 0.92fr 1.08fr; gap: 46px; align-items: center; margin-top: 30px; }
