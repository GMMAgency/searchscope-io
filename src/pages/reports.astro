    .reports .rp-hero .hsub { font-size: 14px; }
    .reports .creamsec { padding: 40px 22px; }
    .reports .ctaband { padding: 40px 24px; }
    .reports .ctaband h2 { font-size: 22px; }
    .reports .sechead h2 { font-size: 21px; }
    .reports .pq { font-size: 19px; margin-top: 64px; }
    .reports .mv { margin-top: 72px; }
  }
  @media (max-width: 520px) {
    .reports .rp-stage { padding: 14px; }
    .reports .rp-paper { padding: 18px 17px 22px; }
