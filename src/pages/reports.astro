---
import BaseLayout from '../layouts/BaseLayout.astro';

// /reports · the reporting layer, ported from the approved interactive
// composer concept. Repo BaseLayout (nav, footer, fonts, count-up),
// repo tokens; the composer is the interactive centrepiece.
---

<BaseLayout
  title="Reports"
  description="One report from your live search data, composed for whoever opens it: the board gets the decision, the marketing team gets the levers, the technical team gets the detail. Send it as a PDF, a slide deck or a workbook."
  headerTheme="dark"
>
  <div class="reports">
    <div class="wrap">
      <!-- hero + composer, on the grid field -->
      <div class="rp-field">
        <div class="rp-hero">
          <span class="eb">Reporting</span>
          <h1>The report writes itself. You just decide who reads it.</h1>
          <div class="rp-alts">
            <span class="rp-alt"><span class="k">or ·</span> Every finding, told the way each stakeholder needs to hear it.</span>
            <span class="rp-alt"><span class="k">or ·</span> The read, reshaped for whoever opens it.</span>
          </div>
          <p class="hsub">Compose a report from your live search data whenever you need one. Pick who's reading and it reshapes itself: <strong>the board gets the headline and the decision, the marketing team gets the levers, the technical team gets the issue detail.</strong> One click sends it as a PDF, a slide deck or a workbook.</p>
          <div class="ctas">
            <a class="cta solid" href="/contact">Join the pilot programme →</a>
            <a class="cta ghost" href="#composer">Try the composer ↓</a>
          </div>
        </div>

        <div class="rp-stagewrap" id="composer">
          <div class="ticked">
            <span class="tks" aria-hidden="true"><i></i><i></i><i></i><i></i></span>
            <div class="appwin" id="rpApp">
              <div class="awbar">
                <span class="awdots" aria-hidden="true"><i></i><i></i><i></i></span>
                <span class="awurl">app.searchscope.io/reporting</span>
                <span class="awtab">Report composer</span>
              </div>
              <div class="rp-comp">
                <!-- control rail -->
                <div class="rp-rail">
                  <div class="rp-lbl">Audience</div>
                  <div class="rp-aud" id="rpAud">
                    <button type="button" data-aud="client">Your client</button>
                    <button type="button" data-aud="exec">Executives</button>
                    <button type="button" data-aud="marketing">Marketing</button>
                    <button type="button" data-aud="technical">Technical</button>
                  </div>

                  <div class="rp-lbl mt">Sections <span id="rpCount"></span></div>
                  <div class="rp-secs" id="rpTogs"></div>

                  <div class="rp-lbl mt">Export</div>
                  <div class="rp-ex" id="rpEx">
                    <button type="button" data-ex="pdf">PDF <span class="k">.pdf</span></button>
                    <button type="button" data-ex="deck">Slide deck <span class="k">.pptx</span></button>
                    <button type="button" data-ex="book">Workbook <span class="k">.xlsx</span></button>
                  </div>
                  <div class="rp-exmsg" id="rpExMsg"></div>

                  <button type="button" class="rp-regen" id="rpRegen">↻ Regenerate</button>

                  <div class="rp-lbl mt">Recent reports</div>
                  <div class="rp-rec"><span>Weekly intelligence</span><span class="rt">w/c 30 Jun</span></div>
                  <div class="rp-rec"><span>Weekly intelligence</span><span class="rt">w/c 23 Jun</span></div>
                  <div class="rp-rec"><span>Monthly review</span><span class="rt">w/c 02 Jun</span></div>
                </div>

                <!-- paper preview -->
                <div class="rp-stage">
                  <div class="rp-paper">
                    <div class="rp-mast">
                      <div class="ml">
                        <span class="tt">Weekly intelligence</span>
                        <span class="ts">Northwind Outfitters · w/c 6 July 2026</span>
                      </div>
                      <div class="mr">Prepared for<br /><b id="rpFor">Your client</b><br />by Searchscope</div>
                    </div>
                    <div class="rp-status" id="rpStatus"><span class="d"></span><span class="t">ready to compose</span></div>
                    <div class="rp-strap" id="rpStrap"></div>
                    <div class="rp-secwrap" id="rpSecs"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <p class="objcap">Client-ready reports that write themselves. Choose the reader; the page rewrites, section by section.</p>

          <div class="statrow">
            <div class="stat"><span class="sv cnt" data-n="4">4</span><span class="sl">readers, one report</span></div>
            <div class="stat"><span class="sv cnt" data-n="3">3</span><span class="sl">export formats</span></div>
            <div class="stat"><span class="sv cnt" data-n="8">8</span><span class="sl">composable sections</span></div>
            <div class="stat"><span class="sv cnt" data-n="0">0</span><span class="sl">logins to read it</span></div>
          </div>
        </div>
      </div>

      <!-- who it's for -->
      <div class="creamsec rv">
        <div class="sechead center">
          <span class="eb">Who it's for</span>
          <h2>The person who signs off never logs in.</h2>
          <p style="margin-inline:auto;max-width:58ch">One composed report, forwarded cold, still lands. Each reader gets the version written for them, and nothing about it looks generated.</p>
        </div>
        <div class="probs">
          <div class="prob">
            <span class="pn">Your client</span>
            <h3>The wins, in plain English</h3>
            <p>What moved, what you shipped and what's next. No jargon, and no dashboard to learn before the good news lands.</p>
          </div>
          <div class="prob">
            <span class="pn">The board</span>
            <h3>Two numbers and a decision</h3>
            <p>The summary is tight enough to read in the meeting it's forwarded to, with the one risk that actually needs a call.</p>
          </div>
          <div class="prob">
            <span class="pn">The team</span>
            <h3>Issue-level detail, logged</h3>
            <p>Every fix applied, every opportunity ranked, the briefs attached. Enough to act on before the next standup.</p>
          </div>
        </div>
      </div>

      <div class="pq rv">
        Proof the work moved the needle, in the language your stakeholders already speak.
        <span class="cite">The read, on demand</span>
      </div>

      <!-- export / formats -->
      <div class="mv rv">
        <div class="two">
          <div class="sechead">
            <span class="eb">One click out</span>
            <h2>One report, three ways to send it.</h2>
            <p>The same composed report leaves as whatever the moment needs. A doc to forward, a slide deck to present, a workbook with every finding to sort and filter. One click, no copy-paste and no reformatting.</p>
          </div>
          <div class="ticked">
            <span class="tks" aria-hidden="true"><i></i><i></i><i></i><i></i></span>
            <div class="rp-formats">
              <div class="rp-fmt"><span class="ext">.pdf</span><div><span class="fn">Portable document</span><span class="fd">The report, ready to forward</span></div><span class="fc">1 click →</span></div>
              <div class="rp-fmt"><span class="ext">.pptx</span><div><span class="fn">Slide deck</span><span class="fd">The five slides that matter</span></div><span class="fc">1 click →</span></div>
              <div class="rp-fmt"><span class="ext">.xlsx</span><div><span class="fn">Workbook</span><span class="fd">Every finding, filterable</span></div><span class="fc">1 click →</span></div>
            </div>
          </div>
        </div>
        <p class="objcap" style="text-align:left;margin-top:22px">One click to PDF or a slide deck. The workbook carries every finding the report summarises.</p>
      </div>

      <!-- cta band -->
      <div class="ctaband rv">
        <span class="eb">Work with us</span>
        <h2>See what your next report could look like.</h2>
        <p>A real strategist points Searchscope at your own site and shows you the first report it composes. No pitch deck, no obligation, just the page your stakeholders would actually read.</p>
        <div class="ctas">
          <a class="cta solid" href="/contact">Join the pilot programme</a>
          <a class="cta ghost" href="/platform">See the platform</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style is:global>
  /* ══════════════════════════════════════════════════════════════
     /reports · a member of the site's light Instrument system.
     Ported from the approved composer concept; namespaced under
     .reports so its generic class names (.appwin, .two, .prob, .pq,
     .sechead …) never collide with the site's globals, and so the
     JS-built composer nodes are styled too. Fonts route to the repo
     tokens; colours are the same light Instrument palette.
     ══════════════════════════════════════════════════════════════ */
  .reports {
    --bg: #fbfbfb; --surface: #ffffff; --surface-2: #f1f1f0;
    --border: rgba(22, 20, 15, 0.11); --ink: #16150f;
    --dim: rgba(22, 20, 15, 0.62); --faint: rgba(22, 20, 15, 0.42);
    --tick: rgba(22, 20, 15, 0.34);
    --cream: #f7f4ee; --cream-2: #efeadf; --paper: #fdfcf8;
    --emerald: #15937A; --rose: #E11D48; --amber: #B45309; --blue: #2563eb;
    /* fonts routed to the repo tokens (no inlined base64 webfonts) */
    --font-ui: var(--font-display);
    color: var(--ink);
    font-family: var(--font-ui);
    -webkit-font-smoothing: antialiased;
    padding: 8px 24px 72px;
  }
  .reports .wrap { max-width: 1060px; margin: 0 auto; }
  /* never leave content hidden if JS is off */
  html.no-js .reports .rv { opacity: 1; transform: none; }

  .reports .eb { font-family: var(--font-mono); font-size: 10.5px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: var(--faint); display: inline-flex; align-items: center; gap: 10px; }
  .reports .eb::before { content: ''; width: 22px; height: 1px; background: currentColor; opacity: 0.6; }
  .reports .rp-field { position: relative; }
  .reports .rp-field::before { content: ''; position: absolute; inset: 0; pointer-events: none; z-index: 0;
  background-image: linear-gradient(to right, rgba(22,20,15,0.05) 1px, transparent 1px), linear-gradient(to bottom, rgba(22,20,15,0.05) 1px, transparent 1px);
  background-size: 56px 56px;
  -webkit-mask-image: radial-gradient(118% 74% at 50% 2%, #000 52%, transparent 92%);
  mask-image: radial-gradient(118% 74% at 50% 2%, #000 52%, transparent 92%); }
  .reports .rp-field > * { position: relative; z-index: 1; }
  .reports .ticked { position: relative; }
  .reports .tks { position: absolute; inset: -13px; pointer-events: none; color: var(--tick); }
  .reports .tks i { position: absolute; width: 16px; height: 16px; border: 0 solid currentColor; }
  .reports .tks i:nth-child(1) { top: 0; left: 0; border-top-width: 1.5px; border-left-width: 1.5px; }
  .reports .tks i:nth-child(2) { top: 0; right: 0; border-top-width: 1.5px; border-right-width: 1.5px; }
  .reports .tks i:nth-child(3) { bottom: 0; right: 0; border-bottom-width: 1.5px; border-right-width: 1.5px; }
  .reports .tks i:nth-child(4) { bottom: 0; left: 0; border-bottom-width: 1.5px; border-left-width: 1.5px; }
  .reports .rp-hero { text-align: center; padding: 64px 24px 38px; }
  .reports .rp-hero .eb { justify-content: center; }
  .reports .rp-hero h1 { font-size: 41px; line-height: 1.06; letter-spacing: -0.032em; font-weight: 580; margin: 16px auto 0; max-width: 19ch; }
  .reports .rp-alts { margin: 16px auto 0; display: flex; flex-direction: column; gap: 4px; align-items: center; }
  .reports .rp-alt { font-family: var(--font-mono); font-size: 11px; color: var(--faint); letter-spacing: 0.005em; }
  .reports .rp-alt .k { color: var(--tick); }
  .reports .rp-hero .hsub { color: var(--dim); font-size: 15px; line-height: 1.64; max-width: 58ch; margin: 22px auto 24px; }
  .reports .rp-hero .hsub strong { color: var(--ink); font-weight: 560; }
  .reports .ctas { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }
  .reports .cta { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-mono); font-size: 11.5px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; padding: 11px 20px; border-radius: 999px; text-decoration: none; cursor: pointer; border: 1px solid transparent; }
  .reports .cta.solid { background: var(--ink); color: #fff; }
  .reports .cta.ghost { border-color: var(--border); color: var(--ink); }
  .reports .rp-stagewrap { padding: 8px 0 6px; }
  .reports .appwin { border: 1px solid var(--border); border-radius: 16px; background: var(--surface); overflow: hidden; box-shadow: 0 1px 2px rgba(22,20,15,0.04), 0 22px 60px -30px rgba(22,20,15,0.28); }
  .reports .awbar { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-bottom: 1px solid var(--border); background: #f7f7f5; }
  .reports .awdots { display: inline-flex; gap: 6px; }
  .reports .awdots i { width: 8px; height: 8px; border-radius: 50%; background: var(--surface-2); border: 1px solid var(--border); display: block; }
  .reports .awurl { font-family: var(--font-mono); font-size: 10.5px; color: var(--faint); flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .reports .awtab { margin-left: auto; font-family: var(--font-mono); font-size: 10px; color: var(--ink); padding: 3px 10px; border-radius: 999px; background: var(--surface-2); white-space: nowrap; }
  .reports .rp-comp { display: grid; grid-template-columns: 246px minmax(0, 1fr); }
  .reports .rp-rail { padding: 18px 18px 22px; border-right: 1px solid var(--border); background: var(--surface); }
  .reports .rp-stage { padding: 22px; background: var(--surface-2); }
  .reports .rp-lbl { font-family: var(--font-mono); font-size: 9.5px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--faint); margin: 0 0 10px; display: flex; align-items: center; justify-content: space-between; gap: 8px; }
  .reports .rp-lbl.mt { margin-top: 22px; }
  .reports .rp-aud { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
  .reports .rp-aud button { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.01em; text-align: left; padding: 9px 11px; border: 1px solid var(--border); border-radius: 9px; background: var(--bg); color: var(--dim); cursor: pointer; transition: background 0.2s, color 0.2s, border-color 0.2s; }
  .reports .rp-aud button:hover { border-color: rgba(22,20,15,0.28); color: var(--ink); }
  .reports .rp-aud button.on { background: var(--ink); color: #fff; border-color: var(--ink); }
  .reports .rp-secs { display: flex; flex-wrap: wrap; gap: 6px; }
  .reports .rp-tog { font-family: var(--font-mono); font-size: 10px; padding: 5px 10px 5px 9px; border-radius: 999px; border: 1px solid var(--border); background: var(--bg); color: var(--faint); cursor: pointer; user-select: none; transition: color 0.2s, border-color 0.2s, background 0.2s; display: inline-flex; align-items: center; }
  .reports .rp-tog::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: currentColor; display: inline-block; margin-right: 6px; opacity: 0.45; }
  .reports .rp-tog:hover { color: var(--ink); border-color: rgba(22,20,15,0.24); }
  .reports .rp-tog.on { color: var(--ink); border-color: rgba(22,20,15,0.32); background: var(--surface); }
  .reports .rp-tog.on::before { background: var(--emerald); opacity: 1; }
  .reports .rp-ex { display: flex; flex-direction: column; gap: 6px; }
  .reports .rp-ex button { font-family: var(--font-mono); font-size: 10.5px; text-align: left; padding: 9px 11px; border: 1px solid var(--border); border-radius: 9px; background: var(--bg); color: var(--ink); cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 10px; transition: border-color 0.2s, color 0.2s; }
  .reports .rp-ex button:hover { border-color: rgba(22,20,15,0.3); }
  .reports .rp-ex button .k { color: var(--faint); font-size: 9px; letter-spacing: 0.04em; }
  .reports .rp-ex button.done { border-color: var(--emerald); color: var(--emerald); }
  .reports .rp-ex button.done .k { color: var(--emerald); }
  .reports .rp-exmsg { margin-top: 10px; font-family: var(--font-mono); font-size: 10px; line-height: 1.4; color: var(--emerald); min-height: 14px; opacity: 0; transform: translateY(3px); transition: opacity 0.35s, transform 0.35s; }
  .reports .rp-exmsg.show { opacity: 1; transform: none; }
  .reports .rp-regen { margin-top: 16px; width: 100%; font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.05em; padding: 10px; border: 1px solid var(--border); border-radius: 9px; background: var(--bg); color: var(--ink); cursor: pointer; transition: border-color 0.2s; }
  .reports .rp-regen:hover { border-color: rgba(22,20,15,0.3); }
  .reports .rp-rec { display: flex; justify-content: space-between; gap: 8px; align-items: baseline; padding: 7px 0; border-bottom: 1px solid var(--border); font-family: var(--font-mono); font-size: 10.5px; color: var(--dim); }
  .reports .rp-rec:last-child { border-bottom: none; }
  .reports .rp-rec .rt { color: var(--faint); font-size: 9px; white-space: nowrap; }
  .reports .rp-paper { background: var(--paper); border: 1px solid rgba(22,20,15,0.1); border-radius: 6px; padding: 26px 30px 30px; max-width: 620px; margin: 0 auto; box-shadow: 0 1px 2px rgba(22,20,15,0.05), 0 14px 34px -18px rgba(22,20,15,0.22); }
  .reports .rp-mast { display: flex; justify-content: space-between; gap: 14px; flex-wrap: wrap; align-items: baseline; border-bottom: 1px solid var(--border); padding-bottom: 13px; }
  .reports .rp-mast .ml .tt { font-size: 17px; font-weight: 575; letter-spacing: -0.02em; }
  .reports .rp-mast .ml .ts { font-family: var(--font-mono); font-size: 9.5px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--faint); margin-top: 4px; display: block; }
  .reports .rp-mast .mr { text-align: right; font-family: var(--font-mono); font-size: 9.5px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--faint); line-height: 1.7; }
  .reports .rp-mast .mr b { color: var(--ink); font-weight: 500; }
  .reports .rp-status { display: flex; align-items: center; gap: 8px; margin: 14px 0 0; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.04em; color: var(--dim); }
  .reports .rp-status .d { width: 6px; height: 6px; border-radius: 50%; background: var(--emerald); flex: none; }
  .reports .rp-status.busy .d { background: var(--blue); animation: rp-pulse 1s ease-in-out infinite; }
  @keyframes rp-pulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.35; transform: scale(0.7); } }
  .reports .rp-strap { font-size: 12.8px; line-height: 1.55; color: var(--ink); font-weight: 500; border-left: 2px solid var(--ink); padding-left: 13px; margin: 13px 0 2px; }
  .reports .rp-secwrap {  }
  .reports .rp-sec { border-top: 1px solid var(--border); padding-top: 15px; margin-top: 17px; opacity: 0; transform: translateY(11px); transition: opacity 0.5s cubic-bezier(0.2,0.7,0.2,1), transform 0.5s cubic-bezier(0.2,0.7,0.2,1), margin 0.35s ease, padding 0.35s ease; overflow: hidden; }
  .reports .rp-sec.in { opacity: 1; transform: none; }
  .reports .rp-sec.out { opacity: 0; transform: translateY(-4px); margin-top: 0; padding-top: 0; max-height: 0; }
  .reports .rp-sec-h { display: flex; justify-content: space-between; align-items: baseline; gap: 10px; margin-bottom: 8px; }
  .reports .rp-kick { font-family: var(--font-mono); font-size: 9.5px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--faint); }
  .reports .rp-flag { font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.06em; color: var(--emerald); opacity: 0; }
  .reports .rp-flag.done { animation: rp-flag 1.5s 0.1s forwards; }
  @keyframes rp-flag { 0% { opacity: 0; } 22% { opacity: 1; } 72% { opacity: 1; } 100% { opacity: 0; } }
  .reports .rp-p { font-size: 12.4px; line-height: 1.62; color: var(--dim); margin: 0; }
  .reports .rp-p b { color: var(--ink); font-weight: 560; }
  .reports .rp-note { font-family: var(--font-mono); font-size: 9.5px; color: var(--faint); margin: 9px 0 0; line-height: 1.5; }
  .reports .rp-kpis { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 8px; margin: 2px 0 10px; }
  .reports .rp-kpi { border: 1px solid var(--border); border-radius: 8px; padding: 9px 11px; background: #fff; }
  .reports .rp-kpi .kl { font-family: var(--font-mono); font-size: 8.5px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--faint); }
  .reports .rp-kpi .kv { font-family: var(--font-mono); font-size: 16px; letter-spacing: -0.02em; margin-top: 5px; font-variant-numeric: tabular-nums; }
  .reports .rp-kpi .kd { font-family: var(--font-mono); font-size: 9.5px; margin-top: 3px; }
  .reports .rp-kpi .kd.up { color: var(--emerald); }
  .reports .rp-kpi .kd.down { color: var(--rose); }
  .reports .rp-list { margin: 2px 0 0; padding: 0; list-style: none; }
  .reports .rp-list li { display: flex; gap: 9px; padding: 6px 0; border-bottom: 1px solid var(--border); font-size: 12.2px; color: var(--dim); line-height: 1.5; }
  .reports .rp-list li:last-child { border-bottom: none; }
  .reports .rp-list .ok { color: var(--emerald); font-family: var(--font-mono); font-size: 11px; flex: none; }
  .reports .rp-list.mono li { font-family: var(--font-mono); font-size: 11px; }
  .reports .rp-list .dd { width: 6px; height: 6px; border-radius: 50%; margin-top: 5px; flex: none; }
  .reports .rp-list .dd.rose { background: var(--rose); }
  .reports .rp-list .dd.amber { background: var(--amber); }
  .reports .rp-list b { color: var(--ink); font-weight: 555; }
  .reports .rp-share { margin: 2px 0 0; }
  .reports .rp-shrow { display: grid; grid-template-columns: 110px minmax(0, 1fr) 34px; gap: 10px; align-items: center; padding: 5px 0; }
  .reports .rp-shrow .n { font-family: var(--font-mono); font-size: 10.5px; color: var(--dim); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .reports .rp-shrow .n.you { color: var(--ink); font-weight: 500; }
  .reports .rp-track { height: 7px; border-radius: 4px; background: var(--surface-2); position: relative; overflow: hidden; }
  .reports .rp-track i { position: absolute; inset: 0 auto 0 0; border-radius: 4px; background: rgba(22,20,15,0.26); display: block; }
  .reports .rp-track i.you { background: var(--ink); }
  .reports .rp-shrow .v { font-family: var(--font-mono); font-size: 10.5px; color: var(--dim); text-align: right; font-variant-numeric: tabular-nums; }
  .reports .rp-quote { margin-top: 11px; border: 1px solid var(--border); border-radius: 9px; background: #fff; padding: 11px 13px; }
  .reports .rp-quote .src { font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--faint); }
