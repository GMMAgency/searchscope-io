  .reports .rp-fmt { display: grid; grid-template-columns: auto minmax(0, 1fr) auto; gap: 16px; align-items: center; padding: 17px 18px; border-bottom: 1px solid var(--border); }
  .reports .rp-fmt:last-child { border-bottom: none; }
  .reports .rp-fmt .ext { font-family: var(--font-mono); font-size: 10px; color: var(--ink); border: 1px solid var(--border); border-radius: 6px; padding: 5px 8px; white-space: nowrap; }
  .reports .rp-fmt .fn { font-size: 14px; font-weight: 560; letter-spacing: -0.012em; }
  .reports .rp-fmt .fd { font-family: var(--font-mono); font-size: 10px; color: var(--faint); margin-top: 2px; display: block; }
  .reports .rp-fmt .fc { font-family: var(--font-mono); font-size: 10px; color: var(--tick); white-space: nowrap; }
  .reports .ctaband { background: var(--ink); color: #fff; border-radius: 18px; padding: 50px 46px; margin-top: 96px; }
  .reports .ctaband .eb { color: rgba(255,255,255,0.5); }
  .reports .ctaband h2 { font-size: 27px; font-weight: 570; letter-spacing: -0.024em; margin: 14px 0 8px; }
  .reports .ctaband p { color: rgba(255,255,255,0.66); font-size: 13.5px; line-height: 1.6; max-width: 54ch; margin: 0 0 22px; }
  .reports .ctaband .cta.solid { background: #fff; color: var(--ink); }
  .reports .ctaband .cta.ghost { border-color: rgba(255,255,255,0.28); color: #fff; }
  .reports .ctaband .ctas { justify-content: flex-start; }
  .reports .rv { opacity: 0; transform: translateY(18px); transition: opacity 0.75s cubic-bezier(0.2,0.7,0.2,1), transform 0.75s cubic-bezier(0.2,0.7,0.2,1); }
  .reports .rv.in { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) {
