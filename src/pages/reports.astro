</style>

<script is:inline>
  (function () {
    var reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* ── scroll reveals (.rv → .in); count-up on .cnt is handled by BaseLayout ── */
    var rvs = [].slice.call(document.querySelectorAll('.reports .rv'));
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (es) {
        es.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
      }, { rootMargin: '0px 0px -6% 0px', threshold: 0.06 });
      rvs.forEach(function (el) { io.observe(el); });
    } else { rvs.forEach(function (el) { el.classList.add('in'); }); }

    /* ══════════════ the report composer ══════════════ */
    var ORDER = ['summary','performance','wins','risks','brand','workspace','actions','plan'];
    var NAMES = {
      summary: 'Executive summary', performance: 'Performance', wins: 'Wins shipped',
      risks: 'Risks & watch-list', brand: 'Brand & AI visibility', workspace: 'Workspace detail',
      actions: 'Actions done', plan: 'Action plan'
    };
    var DRAFT = {
      summary: 'drafting executive summary…', performance: 'pulling performance…',
      wins: 'listing the wins shipped…', risks: 'flagging risks…',
      brand: 'auditing brand & AI visibility…', workspace: 'expanding workspace detail…',
      actions: 'logging actions done…', plan: 'writing the action plan…'
    };

    var AUD = {
      client:    { label: 'Your client',    strap: "Written for your client. Plain English, the wins first, and exactly what happens next.", sections: ['summary','performance','wins','brand','plan'] },
      exec:      { label: 'The board',       strap: "Written for the board. The headline numbers, the one risk that matters, and the decision in front of you.", sections: ['summary','performance','risks','plan'] },
      marketing: { label: 'Marketing team',  strap: "Written for the marketing team. Every lever pulled, with the detail to move on.", sections: ['summary','performance','wins','brand','workspace','plan'] },
      technical: { label: 'Technical team',  strap: "Written for the technical team. Issue-level detail, every fix logged, nothing hand-waved.", sections: ['performance','risks','workspace','actions','plan'] }
    };

    var READS = {
      summary: {
        client: "Good week. Clicks are up <b>6.2%</b>, and the winter-layering guide we rebuilt last month is back on page one, so that traffic is coming home. One thing to keep half an eye on: people are searching for 4-season tents more than ever right now, but your buyer's guide has slipped and a competitor took the top spot. We've already written the fix. It's ready whenever you give the word.",
        exec: "Traffic up <b>6.2%</b> to <b>48,210 clicks</b>. The number that matters: about <b>9,000 clicks a month</b> in tent and boot searches you don't rank for yet. The work to win them is written and waiting. The only call to make is whether we ship it this week or next.",
        marketing: "Clicks <b>+6.2%</b>, impressions <b>+4.1%</b>, average position up <b>1.4 places</b>. Most of that is the winter-layering rebuild paying off. Two levers are open right now: the 4-season tent guide is decaying and needs a refresh, and ‘merino base layers’ is stuck at position 8 on a thin page. Both are briefed below.",
        technical: "Crawl came back clean across <b>412 pages</b>. The position gains line up with last week's canonical fixes on the boot filters. Two live issues worth your time: the tent buyer's guide is down <b>31%</b> over 90 days, and /guides/winter-layering is earning links but still renders slowly on mobile. Specifics below."
      }
    };

    function kpi(l, v, dir, d) {
      return '<div class="rp-kpi"><div class="kl">' + l + '</div><div class="kv">' + v + '</div><div class="kd ' + dir + '">' + d + '</div></div>';
    }

    var BUILD = {
      summary: function (a) {
        return '<p class="rp-p">' + (READS.summary[a] || READS.summary.client) + '</p>';
      },
      performance: function () {
        return '<div class="rp-kpis">' +
          kpi('Clicks', '48,210', 'up', '▲ 6.2%') +
          kpi('Impressions', '1.42M', 'up', '▲ 4.1%') +
          kpi('Avg position', '12.8', 'up', '▲ 1.4') +
          '</div><p class="rp-p">The growth is spread out, not one lucky page. <b>61 pages up</b>, 14 down since last week.</p>';
      },
      wins: function () {
        return '<ul class="rp-list">' +
          '<li><span class="ok">✓</span>Rebuilt the winter-layering guide. Back on page one for ‘how to layer for winter hiking’ after slipping to page three.</li>' +
          '<li><span class="ok">✓</span>Merged the men\'s and women\'s waterproof boot pages into /boots/waterproof, so they stop splitting clicks.</li>' +
          '<li><span class="ok">✓</span>Fixed structured data on 14 product pages. Prices and review stars show in results again.</li>' +
          '<li><span class="ok">✓</span>Wrote two new briefs: a 4-season tent guide and a merino base-layer explainer.</li>' +
          '</ul>';
      },
      risks: function () {
        return '<ul class="rp-list">' +
          '<li><span class="dd rose"></span><span><b>4-season tents:</b> searches are up 18% for the season, but your buyer\'s guide has dropped to page two and cotswoldoutdoor.com took the top spot. Around <b>5,600 clicks a month</b> at stake.</span></li>' +
          '<li><span class="dd amber"></span><span><b>/guides/tent-buying</b> is decaying. Clicks down 31% over 90 days.</span></li>' +
          '<li><span class="dd amber"></span><span>‘merino base layers’ has stalled at position 8. The page is thin, with no sizing or care guidance.</span></li>' +
          '</ul>';
      },
      brand: function () {
        return '<div class="rp-share">' +
          '<div class="rp-shrow"><span class="n you">Northwind</span><span class="rp-track"><i class="you" style="width:44%"></i></span><span class="v">14%</span></div>' +
          '<div class="rp-shrow"><span class="n">Cotswold Outdoor</span><span class="rp-track"><i style="width:82%"></i></span><span class="v">26%</span></div>' +
          '<div class="rp-shrow"><span class="n">Alpkit</span><span class="rp-track"><i style="width:54%"></i></span><span class="v">17%</span></div>' +
          '</div>' +
          '<div class="rp-note">Your share of AI answers for gear questions, up from 9% last month.</div>' +
          '<div class="rp-quote"><span class="src">AI answer · ‘best waterproof hiking boots for the UK’</span>' +
          '<p>The assistants list you as a <b>place to buy</b>, but the recommendations point to brand sites and Cotswold Outdoor. You get mentioned. You rarely get named as the source.</p>' +
          '<div class="verdict">Stocked, not recommended. Two gear round-ups drafted to earn the citation.</div></div>';
      },
      workspace: function () {
        return '<div class="rp-opps">' +
          '<div class="rp-opp"><span class="q">waterproof hiking boots</span><span class="pos">pos 6</span><span class="gain">+3,200</span></div>' +
          '<div class="rp-opp"><span class="q">4-season tent</span><span class="pos">pos 11</span><span class="gain">+5,600</span></div>' +
          '<div class="rp-opp"><span class="q">merino base layers</span><span class="pos">pos 8</span><span class="gain">+2,100</span></div>' +
          '</div><p class="rp-note">3 of 41 open opportunities. The missing subheads and drafted briefs are in the workbook.</p>';
      },
      actions: function () {
        return '<ul class="rp-list mono">' +
          '<li><span class="ok">✓</span>merged /boots/waterproof-mens + -womens → /boots/waterproof · redirects live</li>' +
          '<li><span class="ok">✓</span>canonical fixed · 6 faceted boot-filter URLs</li>' +
          '<li><span class="ok">✓</span>product schema patched · 14 pages · price + rating</li>' +
          '<li><span class="ok">✓</span>flagged /guides/tent-buying · lost 9 internal links since May</li>' +
          '</ul>';
      },
      plan: function () {
        return '<ul class="rp-plan">' +
          '<li><span class="pn">01</span><span><b>Refresh the 4-season tent guide this week.</b> Brief\'s written, target ‘best 4-season tent’.</span></li>' +
          '<li><span class="pn">02</span><span><b>Publish the merino base-layer guide</b> with proper sizing and care sections.</span></li>' +
          '<li><span class="pn">03</span><span><b>Chase two gear round-ups</b> so the AI answers cite you as a source instead of just listing you as a shop.</span></li>' +
          '<li><span class="pn">04</span><span>Point internal links from the boot pages back into the tent guide.</span></li>' +
          '</ul>';
      }
    };

    var app = document.getElementById('rpApp');
    var audWrap = document.getElementById('rpAud');
    var togWrap = document.getElementById('rpTogs');
    var exWrap = document.getElementById('rpEx');
    var secs = document.getElementById('rpSecs');
    var statusEl = document.getElementById('rpStatus');
    var statusT = statusEl.querySelector('.t');
    var strapEl = document.getElementById('rpStrap');
    var forEl = document.getElementById('rpFor');
    var countEl = document.getElementById('rpCount');
    var exMsg = document.getElementById('rpExMsg');

    var current = 'client';
    var enabled = {};
    var composing = false;
    var seq = 0; // guards against overlapping compositions

    /* build the section toggle chips once */
    ORDER.forEach(function (k) {
      var b = document.createElement('span');
      b.className = 'rp-tog';
      b.dataset.key = k;
      b.textContent = NAMES[k];
      b.addEventListener('click', function () { toggleSection(k); });
      togWrap.appendChild(b);
    });

    function orderedKeys() { return ORDER.filter(function (k) { return enabled[k]; }); }

    function setStatus(text, busy) {
      statusT.textContent = text;
      statusEl.classList.toggle('busy', !!busy);
    }

    function syncChrome() {
      var keys = orderedKeys();
      forEl.textContent = AUD[current].label;
      strapEl.innerHTML = AUD[current].strap;
      countEl.textContent = '· ' + keys.length + ' on';
      [].forEach.call(audWrap.children, function (b) { b.classList.toggle('on', b.dataset.aud === current); });
      [].forEach.call(togWrap.children, function (b) { b.classList.toggle('on', !!enabled[b.dataset.key]); });
    }

    function buildSection(k) {
      var el = document.createElement('div');
      el.className = 'rp-sec';
      el.dataset.key = k;
      el.innerHTML = '<div class="rp-sec-h"><span class="rp-kick"></span><span class="rp-flag">drafted ✓</span></div>' +
        '<div class="rp-body">' + BUILD[k](current) + '</div>';
      return el;
    }

    function renumber() {
      [].forEach.call(secs.querySelectorAll('.rp-sec'), function (el, i) {
        var kk = el.querySelector('.rp-kick');
        if (kk) kk.textContent = String(i + 1).padStart(2, '0') + ' · ' + NAMES[el.dataset.key];
      });
    }

    function compose() {
      var mySeq = ++seq;
      composing = true;
      syncChrome();
      secs.innerHTML = '';
      var keys = orderedKeys();

      if (reduced) {
        keys.forEach(function (k) { var el = buildSection(k); el.classList.add('in'); secs.appendChild(el); });
        renumber();
        setStatus('composed · ' + keys.length + ' sections · ready to export', false);
        composing = false;
        return;
      }

      var i = 0;
      (function step() {
        if (mySeq !== seq) return; // superseded
        if (i >= keys.length) {
          setStatus('composed · ' + keys.length + ' sections · ready to export', false);
          composing = false;
          return;
        }
        var k = keys[i];
        setStatus(DRAFT[k], true);
        var el = buildSection(k);
        secs.appendChild(el);
        renumber();
        requestAnimationFrame(function () { requestAnimationFrame(function () { el.classList.add('in'); }); });
        setTimeout(function () { var f = el.querySelector('.rp-flag'); if (f) f.classList.add('done'); }, 250);
        i++;
        setTimeout(step, 320);
      })();
    }

    function setAudience(key) {
      current = key;
      enabled = {};
      AUD[key].sections.forEach(function (k) { enabled[k] = true; });
      clearExports();
      compose();
    }

    function toggleSection(key) {
      if (composing && !reduced) return; // let a composition finish first
      var wasOn = !!enabled[key];
      enabled[key] = !wasOn;
      clearExports();

      if (!enabled[key]) {
        var elOff = secs.querySelector('.rp-sec[data-key="' + key + '"]');
        syncChrome();
        if (elOff) {
          if (reduced) { elOff.remove(); renumber(); }
          else { elOff.classList.add('out'); setTimeout(function () { elOff.remove(); renumber(); }, 400); }
        }
        setStatus('composed · ' + orderedKeys().length + ' sections · ready to export', false);
        return;
      }

      // adding: insert at canonical position
      syncChrome();
      var el = buildSection(key);
      var existing = [].slice.call(secs.querySelectorAll('.rp-sec'));
      var after = null;
      for (var j = 0; j < existing.length; j++) {
        if (ORDER.indexOf(existing[j].dataset.key) > ORDER.indexOf(key)) { after = existing[j]; break; }
      }
      secs.insertBefore(el, after);
      renumber();
      if (reduced) { el.classList.add('in'); setStatus('composed · ' + orderedKeys().length + ' sections · ready to export', false); return; }
      setStatus(DRAFT[key], true);
      requestAnimationFrame(function () { requestAnimationFrame(function () { el.classList.add('in'); }); });
      setTimeout(function () {
        var f = el.querySelector('.rp-flag'); if (f) f.classList.add('done');
        setStatus('composed · ' + orderedKeys().length + ' sections · ready to export', false);
      }, 460);
    }

    function clearExports() {
      [].forEach.call(exWrap.children, function (b) { b.classList.remove('done'); });
      exMsg.classList.remove('show');
    }

    function doExport(kind) {
      var n = orderedKeys().length || 1;
      var map = {
        pdf: 'PDF prepared · ' + n + ' pages · ready to forward',
        deck: 'Slide deck prepared · ' + n + ' slides',
        book: 'Workbook prepared · 214 rows · every finding'
      };
      [].forEach.call(exWrap.children, function (b) { b.classList.toggle('done', b.dataset.ex === kind); });
      exMsg.textContent = '✓ ' + map[kind];
      exMsg.classList.remove('show');
      void exMsg.offsetWidth; // restart transition
      exMsg.classList.add('show');
    }

    /* wire controls */
    [].forEach.call(audWrap.children, function (b) {
      b.addEventListener('click', function () { if (b.dataset.aud !== current || !composing) setAudience(b.dataset.aud); });
    });
    [].forEach.call(exWrap.children, function (b) {
      b.addEventListener('click', function () { doExport(b.dataset.ex); });
    });
    document.getElementById('rpRegen').addEventListener('click', function () { clearExports(); compose(); });

    /* prime state, then compose when the composer scrolls into view */
    enabled = {};
    AUD.client.sections.forEach(function (k) { enabled[k] = true; });
    syncChrome();

    var started = false;
    function kickoff() { if (started) return; started = true; compose(); }
    if ('IntersectionObserver' in window) {
      var aio = new IntersectionObserver(function (es) {
        es.forEach(function (e) { if (e.isIntersecting) { kickoff(); aio.disconnect(); } });
      }, { threshold: 0.25 });
      aio.observe(app);
    } else { kickoff(); }
    /* safety net if it starts in view or observer never fires */
    setTimeout(kickoff, 1200);
  })();
</script>
