---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABand from '../components/CTABand.astro';
import Ticks from '../components/Ticks.astro';
import DemandScatter from '../components/product/DemandScatter.astro';
import DecayTrend from '../components/product/DecayTrend.astro';
import BrandAnswers from '../components/product/BrandAnswers.astro';
import { SITE, GMM } from '../consts';

const problems = [
  { no: '01', label: 'Internal competition', line: "Several pages target one topic, so engines can't tell which is the answer. Rankings swap between URLs and traffic turns unstable." },
  { no: '02', label: 'Repetitive at scale', line: 'Thousands of near-identical template pages blur together in the results. Rankings hold; clicks quietly fall.' },
  { no: '03', label: 'Buried content', line: 'Strong pages sit deep with few internal links, so the system reads them as unimportant, however good they are.' },
];

// The Monday run: seven analysers, one coherent read of a 239-page site.
// Findings reconcile with the stat row (160 total, 4 critical).
const run = [
  { no: '01', nm: 'Index health', st: 'reading index coverage · canonicals · sitemap membership', res: '3 findings · <span class="ok">1 fixed since last week</span>' },
  { no: '02', nm: 'Internal links', st: 'graphing 9,812 internal links · orphan detection', res: '25 findings · <span class="c">1 critical</span>' },
  { no: '03', nm: 'Cannibalisation', st: 'shared-query page pairs · click splits', res: '6 findings · <span class="c">2 critical</span>' },
  { no: '04', nm: 'Content decay', st: '90-day trends across 212 pages with traffic', res: '41 findings · <span class="c">1 critical</span> · 12,400 clicks at risk' },
  { no: '05', nm: 'Opportunities', st: 'positions 4-15 vs heading coverage', res: '49 findings · +8,900 clicks in reach' },
  { no: '06', nm: 'Schema', st: 'structured data vs rich-result eligibility', res: '24 findings · 11 pages fixable today' },
  { no: '07', nm: 'Cluster volatility', st: '214 semantic clusters · trend + coverage', res: '12 findings · 3 clusters need a home' },
];

const capabilities = [
  { no: '01', title: 'The Crawler', href: '/how-it-works', line: 'A full technical crawl of your site (pages, links, schema, content and entities), refreshed and fed straight into the analysers, so every insight reflects how your site looks right now.' },
  { no: '02', title: 'The Analyzer Engine', href: '/analyzers/content-decay', line: 'Finds index bloat, content decay, cannibalisation, orphan pages and more, each one scored, prioritised and explained in plain English, so you know what to fix first.' },
  { no: '03', title: 'Demand & Trends', href: '/platform', line: "Shows where market demand is rising and you're losing share, down to the page, with an opportunity score, so you chase growth that is actually there." },
  { no: '04', title: 'Brand & AI visibility', href: '/brand-and-ai', neu: true, line: 'Brand plays a big role in visibility: AI answers favour brands that get talked about, cited and trusted. Searchscope tracks how the answers and the press describe you, and pairs it with a PR strategist to move the numbers.' },
  { no: '05', title: 'The Strategic Advisor', href: '/platform', line: 'An AI co-pilot you can ask. It answers from your live data, finds the non-obvious and drafts the brief, so the team can move in minutes, not meetings.' },
  { no: '06', title: 'Content Studio', href: '/platform', line: 'Turns an opportunity into a brief (or a full draft) in one step: it reads the live results, finds the gaps, and hands your writers something ready to publish.' },
  { no: '07', title: 'Weekly Intelligence', href: '/how-it-works', line: 'A clear weekly read on what moved and what to do about it, shareable across the team, so nothing important slips by.' },
];

const metaDescription =
  'Searchscope is an AI search intelligence co-pilot for SEO and growth teams. It reads your whole search picture, tells you what to fix and why, and our strategists turn it into growth.';

const softwareLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: SITE.name,
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  url: SITE.url,
  description: metaDescription,
  publisher: { '@type': 'Organization', name: GMM.name, url: GMM.url },
};
---

<BaseLayout description={metaDescription} headerTheme="dark" jsonLd={[softwareLd]}>
  <!-- ============ HERO (live copy, unchanged) ============ -->
  <section class="section hero theme-dark bg-grid">
    <div class="hero__glow" aria-hidden="true"></div>
    <div class="container container--wide">
      <div class="hero__grid">
        <div class="hero__copy">
          <span class="eyebrow reveal">Search intelligence</span>
          <h1 class="hero__title reveal" style="--reveal-delay:60ms">
            The AI co-pilot for modern<br />search&nbsp;teams.
          </h1>
          <p class="hero__sub reveal" style="--reveal-delay:130ms">
            Searchscope reads your whole search picture (your site, your search data, market
            demand and AI search), pinpoints what is costing you traffic, and
            <strong>our strategists turn it into work that ships.</strong>
          </p>
          <div class="hero__actions reveal" style="--reveal-delay:200ms">
            <a href="/contact" class="btn">
              Join the pilot programme
              <span class="btn__arrow" aria-hidden="true">→</span>
            </a>
            <a href="/platform" class="hero__link">
              See the platform
              <span class="btn__arrow" aria-hidden="true">→</span>
            </a>
          </div>
          <p class="hero__note mono reveal" style="--reveal-delay:260ms">
            Built and run by the search team at Growth Minded Marketing.
          </p>
        </div>

        <div class="hero__visual reveal" style="--reveal-delay:160ms">
          <div class="ticked">
            <Ticks size={16} inset="-13px" />
            <DemandScatter />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ THE WORKING WEEK (additive) ============ -->
  <section class="section theme-dark">
    <div class="container container--wide">
      <div class="reveal">
        <span class="eyebrow">The working week</span>
        <div class="sechead" style="margin-top:var(--space-s)">
          <h2 class="big">Know what's costing you traffic. Ship the fix. Every week.</h2>
          <p>
            Every Monday the whole suite reads your site against your search data: seven analysers,
            every page, every query. By the time you open your laptop the findings are scored,
            explained, and the fixes are drafted.
          </p>
        </div>
        <div class="mstatrow">
          <div class="mstat"><span class="sv cnt" data-n="239">239</span><span class="sl">pages read</span></div>
          <div class="mstat"><span class="sv cnt" data-n="41300">41,300</span><span class="sl">queries cross-checked</span></div>
          <div class="mstat"><span class="sv cnt" data-n="160">160</span><span class="sl">findings scored</span></div>
          <div class="mstat"><span class="sv cnt" data-n="4">4</span><span class="sl">critical this week</span></div>
        </div>
      </div>

      <div class="obj runstrip reveal" style="margin-top:var(--space-l)">
        <div class="rs-head">
          <span>Analyzer engine · weekly run</span>
          <span class="mono">02:14</span>
        </div>
        <div class="rows">
          {run.map((r) => (
            <div class="arow done">
              <span class="n">{r.no}</span>
              <span class="nm">{r.nm}</span>
              <span class="st">{r.st}</span>
              <span class="res" set:html={r.res} />
            </div>
          ))}
        </div>
      </div>
      <p class="objcap">The page's one dark object: real engine telemetry, not a fake spinner.</p>
    </div>
  </section>

  <!-- ============ WHY SEO GOT HARDER (live copy) ============ -->
  <section class="section theme-dark">
    <div class="container container--wide">
      <div class="reveal">
        <span class="eyebrow">Why SEO got harder</span>
        <div class="sechead" style="margin-top:var(--space-s)">
          <h2 class="big">Modern search is a system. Most SEO tooling still isn't.</h2>
          <p>
            Search engines and AI systems now read your whole site as a system: what connects, what
            is duplicated, what they can trust. Rank trackers and one-off audits look at pages in
            isolation, so they miss the patterns that actually move traffic.
          </p>
        </div>
        <div class="waves">
          <div class="wave">
            <span class="wn">The first wave</span>
            <h4>The algorithm</h4>
            <p>Optimise for what the engine could measure: keyword placement, links, endless page variations.</p>
          </div>
          <div class="wave">
            <span class="wn">The second wave</span>
            <h4>Write for users</h4>
            <p>Useful content, clear intent, authority and trust. Still right, but no longer enough on its own.</p>
          </div>
          <div class="wave now">
            <span class="wn">The third wave · now</span>
            <h4>Search systems</h4>
            <p>Build a site search engines and AI systems can confidently understand, extract and trust at scale.</p>
          </div>
        </div>
        <p class="pq">
          Designing your website so search engines and AI systems can confidently <em>understand,
          extract and trust</em> your content at scale, not just optimising individual pages to rank.
          <span class="cite">The Search Systems thesis</span>
        </p>
        <div style="text-align:center;margin-top:var(--space-m)">
          <a href="/search-systems" class="golink">Read the full thesis → The future of SEO</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ WHAT IT CATCHES (+ a live catch) ============ -->
  <section class="section theme-dark">
    <div class="container container--wide">
      <div class="reveal">
        <span class="eyebrow">What it catches</span>
        <div class="sechead" style="margin-top:var(--space-s)">
          <h2>Great content, stuck rankings? It is usually one of these.</h2>
          <p>
            You can have strong pages and still stall, because your site isn't clear enough for
            search engines and AI systems to read at scale. Three patterns quietly cap performance,
            and all three are hard to spot by eye.
          </p>
        </div>
        <div class="probs">
          {problems.map((d) => (
            <div class="prob">
              <span class="pn mono">{d.no}</span>
              <h4>{d.label}</h4>
              <p>{d.line}</p>
            </div>
          ))}
        </div>
        <div class="appwin-wrap push"><DecayTrend /></div>
        <div style="margin-top:var(--space-m)">
          <a href="/search-systems" class="golink">See all three, with the data → The future of SEO</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ THE PLATFORM (seven capabilities) ============ -->
  <section class="section theme-dark">
    <div class="container container--wide">
      <div class="reveal">
        <span class="eyebrow">The platform</span>
        <div class="sechead" style="margin-top:var(--space-s)">
          <h2>Your whole search picture, in one place.</h2>
          <p>
            Seven capabilities that crawl your site, surface what is wrong, score what matters and
            draft the work, so your team spends its time acting, not assembling reports.
          </p>
        </div>
        <ul class="capsix" role="list">
          {capabilities.map((c) => (
            <li>
              <span class="no">{c.no}</span>
              <div>
                <h4>{c.title}{c.neu && <span class="newchip">New</span>}</h4>
                <p>{c.line}</p>
              </div>
              <a class="go" href={c.href} aria-label={`More on ${c.title}`}>→</a>
            </li>
          ))}
        </ul>
        <div style="margin-top:var(--space-l)">
          <a href="/platform" class="golink">Explore the platform in full →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ THE STRATEGIC ADVISOR (additive) ============ -->
  <section class="section theme-dark">
    <div class="container container--wide">
      <div class="two reveal">
        <div class="sechead">
          <span class="eyebrow">The Strategic Advisor</span>
          <h2 style="margin-top:var(--space-s)">Ask it what you'd ask an analyst.</h2>
          <p>
            Not a generic chatbot. The Strategic Advisor is grounded in your search reality. Ask it
            where you're losing ground, what's behind a drop, or what to brief next, and it answers
            with the data and the move.
          </p>
          <a href="/platform" class="golink">Meet the advisor → the platform</a>
        </div>
        <div class="appwin">
          <div class="awbar">
            <span class="awdots" aria-hidden="true"><i></i><i></i><i></i></span>
            <span class="awurl">app.searchscope.io/intelligence/advisor</span>
            <span class="awtab">Strategic Advisor</span>
          </div>
          <div class="awbody lchat">
            <div class="cq">which of our pages are quietly losing traffic? nothing's jumped out at me</div>
            <div class="cpull"><span class="ok">✓</span> read 90 days of search data · 239 pages</div>
            <div class="cpull"><span class="ok">✓</span> checked this week's decay run</div>
            <div class="ca">
              <b>Three are sliding while the top-line holds steady, so they're easy to miss:</b>
              <table>
                <tr><td>/journal/winter-layering</td><td class="tx-rose">−34% clicks</td><td class="xtra">demand up 12%</td></tr>
                <tr><td>/boots/waterproof-care</td><td class="tx-rose">−28% clicks</td><td class="xtra">position 5.1 → 8.3</td></tr>
                <tr><td>/tents/4-season</td><td class="tx-rose">−19% clicks</td><td class="xtra">lost 6 brand queries</td></tr>
              </table>
              The shop homepage is growing and masking all three, so your total looks flat. The first
              two already have a refresh playbook from Monday. Want me to open briefs for all three?
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ BRAND & AI VISIBILITY (reputation) ============ -->
  <section class="section theme-dark">
    <div class="container container--wide">
      <div class="reveal">
        <span class="eyebrow">Brand & AI visibility</span>
        <div class="sechead" style="margin-top:var(--space-s)">
          <h2 class="big">Rankings are half the battle. Reputation is the other half.</h2>
          <p>
            Brand plays a big role in visibility. More of your buyers never see a results page: they
            ask an assistant and read one answer, or they read the coverage, and those answers favour
            brands that get talked about, cited and trusted. Searchscope tracks how AI systems and
            the press describe you (your share of the answers, who gets cited, mentions over time)
            and layers digital PR on top, with a PR strategist to move the numbers. It isn't a
            bolt-on. It's how you win visibility now.
          </p>
        </div>
        <div class="appwin-wrap push"><BrandAnswers /></div>
        <div style="margin-top:var(--space-m)">
          <a href="/brand-and-ai" class="golink">The full argument → Brand &amp; AI visibility</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ THE CO-PILOT MODEL (cream) ============ -->
  <section class="section theme-cream">
    <div class="container container--wide">
      <div class="sechead center reveal">
        <span class="eyebrow">The co-pilot model</span>
        <h2 style="margin-top:var(--space-s)">A co-pilot doesn't replace the pilot.</h2>
      </div>
      <div class="hm-grid reveal">
        <div>
          <span class="hm-tag">The machine</span>
          <p class="hm-line">
            Searchscope does hours of analysis in <strong>seconds</strong>, reading your search data
            against demand, your site and AI search to surface what you'd never catch by hand.
          </p>
        </div>
        <span class="hm-x" aria-hidden="true">×</span>
        <div>
          <span class="hm-tag">The humans</span>
          <p class="hm-line">
            Our strategists bring the judgement, context and craft software can't fake, then
            <strong>execute</strong>. Software finds it; people act on it.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ BUILT BY PRACTITIONERS (live copy) ============ -->
  <section class="section theme-dark bbp">
    <div class="container container--wide">
      <div class="bbp__inner reveal">
        <span class="eyebrow">Built by practitioners</span>
        <h2 class="bbp__title">Built and run by a working search team, not a lab.</h2>
        <p class="bbp__sub">
          We're a search team first. Searchscope is the co-pilot we built to do our own client work
          better, sharpened on real sites every day. Work with us and you get both: the intelligence,
          and the people who wield it.
        </p>
        <a href={GMM.url} class="btn btn--ghost btn--lg" target="_blank" rel="noopener">
          Meet the team at Growth Minded Marketing ↗
        </a>
      </div>
    </div>
  </section>

  <!-- ============ FINAL CTA ============ -->
  <CTABand
    title="Be part of our pilot programme"
    secondaryLabel="See the platform"
    secondaryHref="/platform"
  />
</BaseLayout>

<style>
  /* ---------- HERO ---------- */
  .hero {
    padding-top: clamp(3rem, 2rem + 5vw, 6rem);
    overflow: clip;
  }
  .hero__glow {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(60% 50% at 78% 30%, var(--accent-soft), transparent 70%),
      radial-gradient(40% 40% at 10% 80%, color-mix(in oklab, var(--ink) 4%, transparent), transparent 70%);
    pointer-events: none;
  }
  .hero__grid {
    display: grid;
    grid-template-columns: 1.02fr 0.98fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 4.5rem);
  }
  .hero__title {
    font-size: clamp(2.3rem, 1.7rem + 3vw, 4rem);
    line-height: 1.04;
    letter-spacing: -0.035em;
    margin-top: var(--space-s);
  }
  .hero__sub {
    margin-top: var(--space-l);
    font-size: var(--step-1);
    line-height: 1.5;
    color: var(--ink-dim);
    max-width: 44ch;
  }
  .hero__visual {
    position: relative;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-m);
    margin-top: var(--space-l);
  }
  .hero__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-family: var(--font-mono);
    font-size: var(--step-0);
    letter-spacing: 0;
    color: var(--ink);
    transition: color var(--dur) var(--ease-out);
  }
  .hero__link .btn__arrow {
    transition: transform var(--dur) var(--ease-out);
  }
  .hero__link:hover {
    color: var(--ink-dim);
  }
  .hero__link:hover .btn__arrow {
    transform: translateX(3px);
  }
  .hero__note {
    margin-top: var(--space-l);
    font-size: var(--step--1);
    color: var(--ink-faint);
    letter-spacing: 0.02em;
  }
  @media (max-width: 980px) {
    .hero__grid {
      grid-template-columns: 1fr;
    }
    .hero__visual {
      order: -1;
    }
  }

  /* the shared product cards sit centred in their sections */
  .appwin-wrap {
    max-width: 760px;
    margin-inline: auto;
    margin-top: var(--space-l);
  }

  /* ---------- BUILT BY PRACTITIONERS ---------- */
  .bbp__inner {
    max-width: 60ch;
  }
  .bbp__title {
    font-size: var(--step-4);
    margin-top: var(--space-s);
  }
  .bbp__sub {
    margin-top: var(--space-m);
    color: var(--ink-dim);
    font-size: var(--step-1);
    line-height: 1.55;
    max-width: 56ch;
  }
  .bbp__inner .btn {
    margin-top: var(--space-l);
  }
</style>
