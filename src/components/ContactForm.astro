---
import { FORM } from '../consts';
const hasKey = FORM.web3formsKey.length > 0;
---

<form
  class="cform"
  data-contact-form
  data-inbox={FORM.inbox}
  data-mode={hasKey ? 'web3forms' : 'mailto'}
  method="POST"
  action="https://api.web3forms.com/submit"
>
  <!-- Web3Forms config (no backend needed). Set FORM.web3formsKey in src/consts.ts -->
  <input type="hidden" name="access_key" value={FORM.web3formsKey} />
  <input type="hidden" name="subject" value="New Searchscope enquiry" />
  <input type="hidden" name="from_name" value="Searchscope" />
  <!-- honeypot -->
  <input type="checkbox" name="botcheck" class="cform__hp" tabindex="-1" autocomplete="off" />

  <div class="cform__row">
    <div class="cform__field">
      <label for="cf-name">Your name</label>
      <input id="cf-name" name="name" type="text" autocomplete="name" required placeholder="Jane Doe" />
    </div>
    <div class="cform__field">
      <label for="cf-email">Email</label>
      <input id="cf-email" name="email" type="email" autocomplete="email" required placeholder="jane@company.com" />
    </div>
  </div>

  <div class="cform__row">
    <div class="cform__field">
      <label for="cf-company">Company</label>
      <input id="cf-company" name="company" type="text" autocomplete="organization" placeholder="Company Ltd" />
    </div>
    <div class="cform__field">
      <label for="cf-website">Website</label>
      <input id="cf-website" name="website" type="text" inputmode="url" placeholder="company.com" />
    </div>
  </div>

  <div class="cform__field">
    <label for="cf-grow">What are you trying to grow?</label>
    <textarea
      id="cf-grow"
      name="goal"
      rows="4"
      placeholder="e.g. We're losing ground on our money pages and AI Overviews are eating our clicks. We want to understand where to focus."
    ></textarea>
  </div>

  <button type="submit" class="btn btn--lg cform__submit">
    <span class="cform__submit-label">Send to a strategist</span>
    <span class="btn__arrow" aria-hidden="true">→</span>
  </button>

  <p class="cform__status" data-form-status role="status" aria-live="polite"></p>

  <p class="cform__privacy mono">
    We only use your details to reply. No lists, no sharing. <a href="/privacy">Privacy</a>.
  </p>
</form>

<style>
  .cform {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }
  .cform__hp {
    position: absolute !important;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }
  .cform__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-m);
  }
  .cform__field {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .cform__field label {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-dim);
  }
  .cform input,
  .cform textarea {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-s);
    padding: 0.8rem 0.9rem;
    color: var(--ink);
    font-size: var(--step-0);
    transition: border-color var(--dur) var(--ease-out), box-shadow var(--dur) var(--ease-out);
  }
  .cform input::placeholder,
  .cform textarea::placeholder {
    color: var(--ink-faint);
  }
  .cform input:focus,
  .cform textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }
  .cform textarea {
    resize: vertical;
    min-height: 7rem;
    line-height: 1.5;
  }
  .cform__submit {
    align-self: flex-start;
    margin-top: var(--space-2xs);
  }
  .cform__submit[disabled] {
    opacity: 0.6;
    pointer-events: none;
  }
  .cform__status {
    font-size: var(--step--1);
    color: var(--ink-dim);
    min-height: 1.2em;
  }
  .cform__status[data-state='ok'] {
    color: var(--accent);
  }
  .cform__status[data-state='err'] {
    color: var(--sev-rose);
  }
  .cform__privacy {
    font-size: var(--step--2);
    color: var(--ink-faint);
    line-height: 1.5;
  }
  .cform__privacy a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media (max-width: 560px) {
    .cform__row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
  if (form) {
    const status = form.querySelector<HTMLElement>('[data-form-status]');
    const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const mode = form.dataset.mode;
    const inbox = form.dataset.inbox || '';

    const setStatus = (msg: string, state: '' | 'ok' | 'err' = '') => {
      if (!status) return;
      status.textContent = msg;
      if (state) status.dataset.state = state;
      else delete status.dataset.state;
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      if (data.get('botcheck')) return; // honeypot tripped

      const name = String(data.get('name') || '');
      const email = String(data.get('email') || '');
      const company = String(data.get('company') || '');
      const website = String(data.get('website') || '');
      const goal = String(data.get('goal') || '');

      // Fallback: no API key configured → open a pre-filled email.
      if (mode !== 'web3forms') {
        const body = encodeURIComponent(
          `Name: ${name}\nEmail: ${email}\nCompany: ${company}\nWebsite: ${website}\n\nWhat we're trying to grow:\n${goal}`
        );
        const subject = encodeURIComponent('Searchscope enquiry');
        window.location.href = `mailto:${inbox}?subject=${subject}&body=${body}`;
        setStatus('Opening your email app…', 'ok');
        return;
      }

      btn?.setAttribute('disabled', '');
      setStatus('Sending…');
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: data,
        });
        const json = await res.json();
        if (res.ok && json.success) {
          form.reset();
          setStatus("Got it, a strategist will read your search picture and be in touch shortly.", 'ok');
        } else {
          setStatus(json.message || 'Something went wrong. Please email us directly.', 'err');
        }
      } catch {
        setStatus('Network error. Please email us directly.', 'err');
      } finally {
        btn?.removeAttribute('disabled');
      }
    });
  }
</script>
