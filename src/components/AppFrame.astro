---
/**
 * App-window chrome that wraps a product-UI mock (or a real screenshot
 * once supplied). Gives the data viz a credible "this is the product" frame,
 * and is framed with viewfinder corner-ticks by default (the product-frame
 * motif that echoes the logomark). The ticks live on an outer wrapper because
 * the frame itself clips its content with overflow:hidden.
 */
import Ticks from './Ticks.astro';
interface Props {
  label?: string;
  tab?: string;
  class?: string;
  /** viewfinder corner-ticks around the frame (opt-in, for the signature
      frame on a page only — keeps the motif a focal accent, not repetition) */
  ticks?: boolean;
}
const {
  label = 'app.searchscope.io',
  tab = 'Demand & Trends',
  class: cls = '',
  ticks = false,
} = Astro.props;
---

<div class={`app-frame-wrap ${cls}`}>
  {ticks && <Ticks size={18} inset="-13px" />}
  <div class="app-frame">
    <div class="app-frame__bar">
      <span class="app-frame__dots" aria-hidden="true">
        <i></i><i></i><i></i>
      </span>
      <span class="app-frame__url mono">{label}</span>
      <span class="app-frame__tab mono">{tab}</span>
    </div>
    <div class="app-frame__body">
      <slot />
    </div>
  </div>
</div>

<style>
  .app-frame-wrap {
    position: relative;
  }
  .app-frame {
    border: 1px solid var(--hairline);
    border-radius: var(--radius-l);
    background: var(--surface-panel);
    overflow: hidden;
    box-shadow: var(--shadow-l);
  }
  .app-frame__bar {
    display: flex;
    align-items: center;
    gap: var(--space-s);
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--hairline);
    background: color-mix(in oklab, var(--surface-panel) 75%, var(--surface));
  }
  .app-frame__dots {
    display: inline-flex;
    gap: 6px;
  }
  /* monochrome window dots — colour is reserved for data, not chrome */
  .app-frame__dots i {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--hairline);
    border: 1px solid color-mix(in oklab, var(--ink-faint) 30%, var(--hairline));
    display: block;
  }
  .app-frame__url {
    font-size: var(--step--2);
    color: var(--ink-faint);
  }
  .app-frame__tab {
    margin-left: auto;
    font-size: var(--step--2);
    color: var(--accent);
    padding: 0.25em 0.7em;
    border-radius: var(--radius-pill);
    background: var(--accent-soft);
  }
  .app-frame__body {
    padding: clamp(1rem, 2.5vw, 1.6rem);
  }
</style>
