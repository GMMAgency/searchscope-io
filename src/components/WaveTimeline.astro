---
/**
 * The Three Waves of SEO, Technical → Content → Search Systems.
 * A rising connector draws in on scroll; the third wave is the accent.
 */
const waves = [
  {
    no: '01',
    title: 'The Algorithm',
    line: 'Optimise for what the engine could measure: keyword placement, links, endless page variations.',
    era: 'The first wave',
  },
  {
    no: '02',
    title: 'Write for Users',
    line: 'Useful content, clear intent, authority and trust. Still right, but no longer enough on its own.',
    era: 'The second wave',
  },
  {
    no: '03',
    title: 'Search Systems',
    line: 'Build a site search engines and AI systems can confidently understand, extract and trust at scale.',
    era: 'The third wave',
    accent: true,
  },
];
---

<div class="waves reveal">
  <svg class="waves__line" viewBox="0 0 1000 80" preserveAspectRatio="none" aria-hidden="true">
    <path class="waves__track" d="M40 64 Q 250 64 340 44 T 660 24 T 960 8" />
    <path class="waves__draw" d="M40 64 Q 250 64 340 44 T 660 24 T 960 8" />
    <circle class="waves__node" cx="40" cy="64" r="5" />
    <circle class="waves__node" cx="500" cy="32" r="5" />
    <circle class="waves__node waves__node--accent" cx="960" cy="8" r="7" />
  </svg>

  <ol class="waves__grid" role="list">
    {
      waves.map((w) => (
        <li class={`wave ${w.accent ? 'wave--accent' : ''}`}>
          <span class="wave__era mono">{w.era}</span>
          <span class="wave__no mono">{w.no}</span>
          <h3 class="wave__title">{w.title}</h3>
          <p class="wave__line">{w.line}</p>
        </li>
      ))
    }
  </ol>

  <p class="waves__close">
    People read pages like humans. <strong>Search engines and LLMs read websites like systems.</strong>
    Win the third wave and performance stops being a guess.
  </p>
</div>

<style>
  .waves {
    position: relative;
  }
  .waves__line {
    width: 100%;
    height: 70px;
    margin-bottom: var(--space-l);
  }
  .waves__track {
    fill: none;
    stroke: var(--hairline);
    stroke-width: 1.5;
  }
  .waves__draw {
    fill: none;
    stroke: var(--accent);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-dasharray: 1300;
    stroke-dashoffset: 1300;
    transition: stroke-dashoffset 1.8s var(--ease-out);
  }
  .reveal.is-in .waves__draw {
    stroke-dashoffset: 0;
  }
  .waves__node {
    fill: var(--surface);
    stroke: var(--ink-faint);
    stroke-width: 1.5;
  }
  .waves__node--accent {
    fill: var(--accent);
    stroke: var(--accent);
  }

  .waves__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-l);
  }
  .wave {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: var(--space-m);
    border-top: 2px solid var(--hairline);
  }
  .wave--accent {
    border-top-color: var(--accent);
  }
  .wave__era {
    font-size: var(--step--2);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .wave--accent .wave__era {
    color: var(--accent);
  }
  .wave__no {
    font-size: var(--step-1);
    color: var(--ink-dim);
  }
  .wave--accent .wave__no {
    color: var(--accent);
  }
  .wave__title {
    font-size: var(--step-2);
  }
  .wave--accent .wave__title {
    color: var(--ink);
  }
  .wave__line {
    color: var(--ink-dim);
    font-size: var(--step-0);
    max-width: 32ch;
  }

  .waves__close {
    margin-top: var(--space-2xl);
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: var(--step-2);
    line-height: 1.25;
    letter-spacing: -0.02em;
    max-width: 30ch;
    color: var(--ink-dim);
  }
  .waves__close strong {
    color: var(--ink);
    font-weight: 600;
  }

  @media (max-width: 760px) {
    .waves__line {
      display: none;
    }
    .waves__grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }
</style>
