---
/**
 * Mock of a Demand & Trends cluster card — matched to the real app: score
 * badge, intent tag, losing-share flag, demand vs visibility QoQ with
 * sparklines, the position gradient bar, and the ranking-pages line.
 */
function spark(series: number[], w = 80, h = 24) {
  const max = Math.max(...series);
  const min = Math.min(...series);
  const step = w / (series.length - 1);
  return series
    .map((v, i) => `${i === 0 ? 'M' : 'L'}${(i * step).toFixed(1)} ${(h - ((v - min) / (max - min || 1)) * h).toFixed(1)}`)
    .join(' ');
}
const demand = [3, 4, 3, 5, 4, 6, 5, 7, 9, 8, 11, 13];
const visibility = [9, 8, 8, 7, 8, 7, 6, 7, 6, 5, 4, 3];
const posPct = 59.7 / 80; // position on the 1..80 bar
---

<div class="clus" role="img" aria-label="A demand cluster card: Content Strategy for SEO, score 93, losing share, demand up 108% while visibility falls 67%, average position 59.7.">
  <header class="clus__head">
    <span class="clus__score">
      <span class="clus__score-v mono">93</span>
      <span class="clus__score-l mono">SCORE</span>
    </span>
    <span class="clus__title-wrap">
      <span class="clus__title">Content Strategy for SEO</span>
      <span class="clus__tags">
        <span class="clus__tag mono">Informational</span>
        <span class="clus__flag mono">⚠ Losing share</span>
      </span>
    </span>
  </header>

  <div class="clus__qoq">
    <div class="clus__metric">
      <span class="clus__metric-l mono">DEMAND QoQ</span>
      <span class="clus__metric-v mono clus__up">↗ +108%</span>
      <svg class="clus__spark" viewBox="0 0 80 24" preserveAspectRatio="none" aria-hidden="true">
        <path d={spark(demand)} class="clus__sparkline clus__sparkline--up" />
      </svg>
    </div>
    <div class="clus__metric">
      <span class="clus__metric-l mono">VISIBILITY QoQ</span>
      <span class="clus__metric-v mono clus__down">↘ −67%</span>
      <svg class="clus__spark" viewBox="0 0 80 24" preserveAspectRatio="none" aria-hidden="true">
        <path d={spark(visibility)} class="clus__sparkline clus__sparkline--down" />
      </svg>
    </div>
  </div>

  <div class="clus__pos">
    <div class="clus__posrow mono">
      <span>Position <strong>59.7</strong></span>
      <span class="clus__cap">you capture <strong>0%</strong></span>
    </div>
    <div class="clus__bar" aria-hidden="true">
      <span class="clus__dot" style={`left:${posPct * 100}%`}></span>
    </div>
  </div>

  <p class="clus__ranks mono">
    Ranks via <span class="clus__path">/blog/seo-content-strategy</span> · 5,222 impr · 0 clicks
    <span class="clus__warn">⚠ 2 competing</span>
  </p>
</div>

<style>
  .clus {
    border: 1px solid var(--hairline);
    border-radius: var(--radius-m);
    background: var(--surface-panel);
    padding: var(--space-m);
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    font-size: var(--step--1);
  }
  .clus__head {
    display: flex;
    align-items: flex-start;
    gap: 0.8rem;
  }
  .clus__score {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0.35rem 0.5rem;
    border-radius: var(--radius-s);
    background: color-mix(in oklab, var(--sev-rose) 14%, transparent);
    border: 1px solid color-mix(in oklab, var(--sev-rose) 30%, transparent);
    flex: none;
  }
  .clus__score-v {
    font-size: var(--step-2);
    font-weight: 600;
    color: var(--sev-rose);
    line-height: 1;
  }
  .clus__score-l {
    font-size: 0.5rem;
    letter-spacing: 0.1em;
    color: var(--sev-rose);
  }
  .clus__title-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
  }
  .clus__title {
    font-weight: 600;
    color: var(--ink);
    font-size: var(--step-0);
  }
  .clus__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .clus__tag {
    font-size: var(--step--2);
    padding: 0.15em 0.5em;
    border-radius: var(--radius-pill);
    border: 1px solid var(--hairline);
    color: var(--ink-dim);
  }
  .clus__flag {
    font-size: var(--step--2);
    padding: 0.15em 0.5em;
    border-radius: var(--radius-pill);
    color: var(--sev-rose);
    background: color-mix(in oklab, var(--sev-rose) 12%, transparent);
  }

  .clus__qoq {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem;
  }
  .clus__metric {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 0.3rem 0.5rem;
    padding: 0.5rem 0.6rem;
    border: 1px solid var(--hairline);
    border-radius: var(--radius-s);
    background: var(--surface);
  }
  .clus__metric-l {
    font-size: 0.55rem;
    letter-spacing: 0.06em;
    color: var(--ink-faint);
  }
  .clus__metric-v {
    font-size: var(--step--1);
    font-variant-numeric: tabular-nums;
  }
  .clus__up { color: var(--sev-emerald); }
  .clus__down { color: var(--sev-rose); }
  .clus__spark {
    grid-column: 1 / -1;
    width: 100%;
    height: 22px;
  }
  .clus__sparkline {
    fill: none;
    stroke-width: 1.6;
    vector-effect: non-scaling-stroke;
  }
  .clus__sparkline--up { stroke: var(--sev-emerald); }
  .clus__sparkline--down { stroke: var(--sev-rose); }

  .clus__pos {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .clus__posrow {
    display: flex;
    justify-content: space-between;
    font-size: var(--step--2);
    color: var(--ink-dim);
  }
  .clus__posrow strong {
    color: var(--ink);
  }
  .clus__bar {
    position: relative;
    height: 6px;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--sev-emerald), var(--sev-amber) 55%, var(--sev-rose));
  }
  .clus__dot {
    position: absolute;
    top: 50%;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--ink);
    border: 2px solid var(--surface-panel);
    transform: translate(-50%, -50%);
  }
  .clus__ranks {
    font-size: var(--step--2);
    color: var(--ink-faint);
    line-height: 1.5;
  }
  .clus__path { color: var(--ink-dim); }
  .clus__warn { color: var(--sev-amber); }
</style>
