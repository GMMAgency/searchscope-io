---
/**
 * Mock of the Command Centre / Weekly Intelligence — the app's signature
 * inverted metric cards (dark-on-light / light-on-dark) + a digest of what
 * moved. Matched to the real app (GSC metrics, coloured deltas).
 */
const metrics = [
  { l: 'TOTAL CLICKS', v: '4.2K', d: '27.3%', dir: 'down', bad: true, note: '5.8K prev' },
  { l: 'IMPRESSIONS', v: '5.8M', d: '46.6%', dir: 'down', bad: true, note: '10.9M prev' },
  { l: 'AVG CTR', v: '0.07%', d: '36.2%', dir: 'up', bad: false, note: '0.05% prev' },
  { l: 'AVG POSITION', v: '29.2', d: '13.1%', dir: 'up', bad: false, note: '25.8 prev' },
];
const moves = [
  { dir: 'up', what: 'Demand for "ai seo audit"', detail: '+18%, you rank #6' },
  { dir: 'down', what: '/pricing share', detail: '−7pts, cannibalisation' },
  { dir: 'up', what: '3 posts entered AI Overviews', detail: 'add answer blocks' },
];
---

<div class="wkly" role="img" aria-label="Command Centre: total clicks, impressions, CTR and average position with week-on-week deltas, plus a digest of what moved.">
  <div class="wkly__cards">
    {
      metrics.map((m) => (
        <div class="wkly__card">
          <span class="wkly__card-l mono">{m.l}</span>
          <span class="wkly__card-v">{m.v}</span>
          <span class={`wkly__card-d mono wkly__card-d--${m.bad ? 'bad' : 'good'}`}>
            {m.dir === 'up' ? '↗' : '↘'} {m.d}
          </span>
        </div>
      ))
    }
  </div>

  <ul class="wkly__moves" role="list">
    {
      moves.map((m) => (
        <li class="wkly__row">
          <span class={`wkly__arrow wkly__arrow--${m.dir}`} aria-hidden="true">{m.dir === 'up' ? '↗' : '↘'}</span>
          <span class="wkly__main">
            <span class="wkly__what">{m.what}</span>
            <span class="wkly__detail">{m.detail}</span>
          </span>
        </li>
      ))
    }
  </ul>
</div>

<style>
  .wkly {
    font-size: var(--step--1);
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }
  .wkly__cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }
  /* inverted card — dark-on-light in light mode, light-on-dark in dark mode */
  .wkly__card {
    background: var(--ink);
    border-radius: var(--radius-s);
    padding: 0.6rem 0.7rem;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }
  .wkly__card-l {
    font-size: 0.56rem;
    letter-spacing: 0.08em;
    color: color-mix(in oklab, var(--surface) 55%, transparent);
  }
  .wkly__card-v {
    font-size: var(--step-2);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--surface);
    line-height: 1.05;
  }
  .wkly__card-d {
    font-size: 0.6rem;
    font-variant-numeric: tabular-nums;
  }
  .wkly__card-d--bad { color: var(--sev-rose); }
  .wkly__card-d--good { color: var(--sev-emerald); }

  .wkly__moves {
    display: flex;
    flex-direction: column;
  }
  .wkly__row {
    display: flex;
    gap: 0.6rem;
    padding: 0.45rem 0;
    border-bottom: 1px solid var(--hairline);
    align-items: flex-start;
  }
  .wkly__row:last-child { border-bottom: 0; }
  .wkly__arrow {
    font-size: 0.95rem;
    line-height: 1.2;
  }
  .wkly__arrow--up { color: var(--sev-emerald); }
  .wkly__arrow--down { color: var(--sev-rose); }
  .wkly__main {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }
  .wkly__what {
    color: var(--ink);
    font-weight: 500;
    font-size: var(--step--1);
  }
  .wkly__detail {
    color: var(--ink-dim);
    font-size: var(--step--2);
  }
</style>
