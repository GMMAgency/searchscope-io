---
/**
 * Light/dark mode toggle. Flips <html data-mode> and remembers the choice.
 * Shows a moon in light mode (click → dark) and a sun in dark mode
 * (click → light). Pre-paint mode is set in BaseLayout to avoid flashes.
 */
---

<button class="mode-toggle" type="button" data-mode-toggle aria-label="Switch colour theme">
  <svg class="mode-toggle__icon mode-toggle__moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.6 6.6 0 0 0 9.8 9.8Z" />
  </svg>
  <svg class="mode-toggle__icon mode-toggle__sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
  </svg>
</button>

<style>
  .mode-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: var(--radius-pill);
    border: 1px solid var(--hairline);
    color: var(--ink-dim);
    background: transparent;
    transition:
      color var(--dur) var(--ease-out),
      border-color var(--dur) var(--ease-out),
      background var(--dur) var(--ease-out);
  }
  .mode-toggle:hover {
    color: var(--ink);
    border-color: color-mix(in oklab, var(--accent) 45%, var(--hairline));
    background: var(--surface-panel);
  }
  .mode-toggle__icon {
    display: none;
  }
  /* show the icon for the action available in the current mode */
  :global(html[data-mode='light']) .mode-toggle__moon {
    display: block;
  }
  :global(html[data-mode='dark']) .mode-toggle__sun {
    display: block;
  }
  /* sensible fallback if data-mode is somehow unset */
  :global(html:not([data-mode='dark'])) .mode-toggle__moon {
    display: block;
  }
  :global(html[data-mode='dark']) .mode-toggle__moon {
    display: none;
  }
</style>

<script>
  const KEY = 'ss-mode';
  const root = document.documentElement;
  const toggles = document.querySelectorAll<HTMLButtonElement>('[data-mode-toggle]');
  const sync = () => {
    const mode = root.dataset.mode === 'dark' ? 'dark' : 'light';
    toggles.forEach((b) =>
      b.setAttribute('aria-label', mode === 'dark' ? 'Switch to light theme' : 'Switch to dark theme')
    );
  };
  toggles.forEach((b) =>
    b.addEventListener('click', () => {
      const next = root.dataset.mode === 'dark' ? 'light' : 'dark';
      root.dataset.mode = next;
      try {
        localStorage.setItem(KEY, next);
      } catch {}
      sync();
    })
  );
  sync();
</script>
