---
import Icon from './Icon.astro';

interface Props {
  icon: 'scatter' | 'analyzer' | 'advisor' | 'pulse' | 'crawl' | 'studio';
  no: string;
  title: string;
  /** When set, the title links through (e.g. to /platform#section) */
  href?: string;
  class?: string;
}
const { icon, no, title, href, class: cls = '' } = Astro.props;
const TitleTag = href ? 'a' : 'div';
---

<article class={`cap card reveal ${cls}`}>
  {Astro.slots.has('visual') && (
    <div class="cap__visual">
      <slot name="visual" />
    </div>
  )}
  <div class="cap__head">
    <span class="cap__icon"><Icon name={icon} size={20} /></span>
    <span class="cap__no mono">{no}</span>
  </div>
  <TitleTag class="cap__title" {...href ? { href } : {}}>{title}</TitleTag>
  <p class="cap__body"><slot /></p>
</article>

<style>
  .cap {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    padding: var(--space-m);
  }
  .cap__visual {
    margin: calc(-1 * var(--space-m)) calc(-1 * var(--space-m)) var(--space-xs);
    border-bottom: 1px solid var(--hairline);
    border-radius: var(--radius-m) var(--radius-m) 0 0;
    overflow: hidden;
    background: color-mix(in oklab, var(--surface) 60%, var(--surface-panel));
  }
  .cap__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .cap__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: var(--radius-s);
    background: var(--accent-soft);
    color: var(--accent);
  }
  .cap__no {
    font-size: var(--step--1);
    color: var(--ink-faint);
  }
  .cap__title {
    font-family: var(--font-heading);
    font-size: var(--step-2);
    font-weight: var(--wt-heading);
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--ink);
  }
  a.cap__title {
    transition: color var(--dur) var(--ease-out);
  }
  a.cap__title:hover {
    color: var(--accent);
  }
  .cap__body {
    color: var(--ink-dim);
    font-size: var(--step-0);
    line-height: 1.55;
  }
</style>
