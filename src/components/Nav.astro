---
import Logo from './Logo.astro';
import ModeToggle from './ModeToggle.astro';
import { NAV_LINKS, SHOW_MODE_TOGGLE } from '../consts';

interface Props {
  /** Matches the hero theme of the page so nav text contrasts correctly */
  theme?: 'dark' | 'cream';
}
const { theme = 'dark' } = Astro.props;

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => {
  const clean = href.replace(/\/$/, '') || '/';
  if (clean === '/') return path === '/';
  return path === clean || path.startsWith(clean + '/');
};
---

<header class={`site-header theme-${theme}`} data-site-header>
  <div class="container container--wide site-header__inner">
    <Logo />

    <div class="header-right">
      <nav class="nav-desktop" aria-label="Primary">
        <ul role="list" class="nav-list">
          {
            NAV_LINKS.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="nav-link"
                  aria-current={isActive(l.href) ? 'page' : undefined}
                >
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
        <a href="/contact" class="btn nav-cta">Join the pilot programme</a>
      </nav>

      {SHOW_MODE_TOGGLE && <ModeToggle />}

      <button
        class="nav-toggle"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
        data-nav-toggle
      >
        <span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div class="nav-mobile" id="mobile-nav" data-nav-mobile hidden>
    <ul role="list" class="nav-mobile__list">
      {
        NAV_LINKS.map((l) => (
          <li>
            <a href={l.href} class="nav-mobile__link" aria-current={isActive(l.href) ? 'page' : undefined}>
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>
    <a href="/contact" class="btn btn--lg nav-mobile__cta">Join the pilot programme</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
    color: var(--ink);
    transition: background var(--dur) var(--ease-out), border-color var(--dur) var(--ease-out);
    border-bottom: 1px solid transparent;
  }
  /* Frosted backdrop once the page scrolls */
  .site-header[data-scrolled] {
    background: color-mix(in oklab, var(--surface) 80%, transparent);
    -webkit-backdrop-filter: saturate(140%) blur(14px);
    backdrop-filter: saturate(140%) blur(14px);
    border-bottom-color: var(--hairline);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-l);
    min-height: 4.5rem;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: clamp(0.5rem, 1.5vw, 1rem);
  }

  .nav-desktop {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2vw, 2.25rem);
  }
  .nav-list {
    display: flex;
    align-items: center;
    gap: clamp(0.75rem, 1.6vw, 1.75rem);
  }
  .nav-link {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    font-weight: 400;
    letter-spacing: 0;
    color: var(--ink-dim);
    padding: 0.4em 0;
    position: relative;
    transition: color var(--dur) var(--ease-out);
  }
  .nav-link:hover {
    color: var(--ink);
  }
  .nav-link[aria-current='page'] {
    color: var(--ink);
  }
  .nav-link[aria-current='page']::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 1.5px;
    background: var(--accent);
    border-radius: 2px;
  }
  .nav-cta {
    font-size: var(--step--1);
    padding: 0.7em 1.15em;
  }

  /* Mobile toggle */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    align-items: center;
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 1.8px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform var(--dur) var(--ease-out), opacity var(--dur) var(--ease-out);
  }
  .nav-toggle[aria-expanded='true'] span:first-child {
    transform: translateY(3.4px) rotate(45deg);
  }
  .nav-toggle[aria-expanded='true'] span:last-child {
    transform: translateY(-3.4px) rotate(-45deg);
  }

  .nav-mobile {
    display: none;
    flex-direction: column;
    gap: var(--space-m);
    padding: var(--space-l) var(--gutter) var(--space-2xl);
    background: var(--surface);
    border-bottom: 1px solid var(--hairline);
  }
  .nav-mobile:not([hidden]) {
    display: flex;
  }
  .nav-mobile__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }
  .nav-mobile__link {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--step-2);
    font-weight: 500;
    letter-spacing: -0.02em;
    padding: 0.45em 0;
    color: var(--ink);
    border-bottom: 1px solid var(--hairline);
  }
  .nav-mobile__link[aria-current='page'] {
    color: var(--accent);
  }
  .nav-mobile__cta {
    margin-top: var(--space-xs);
    width: 100%;
  }

  @media (max-width: 860px) {
    .nav-desktop {
      display: none;
    }
    .nav-toggle {
      display: flex;
    }
  }
</style>

<script>
  // Frosted backdrop on scroll + mobile drawer toggle.
  const header = document.querySelector<HTMLElement>('[data-site-header]');
  const onScroll = () => {
    if (!header) return;
    if (window.scrollY > 8) header.setAttribute('data-scrolled', '');
    else header.removeAttribute('data-scrolled');
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const drawer = document.querySelector<HTMLElement>('[data-nav-mobile]');
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    toggle.setAttribute('aria-label', open ? 'Open menu' : 'Close menu');
    if (drawer) drawer.hidden = open;
    document.body.style.overflow = open ? '' : 'hidden';
  });
</script>
