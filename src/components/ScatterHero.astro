---
/**
 * "Demand & Trends" scatter — matched to the real Searchscope app.
 * x = your position (better → worse), y = demand/mo (log), bubble size =
 * demand, colour = trend (green rising / grey flat / red falling). The
 * shaded zone = rising demand you rank weakly for (your opportunities).
 * Deterministic data (seeded) so the build is stable.
 */
interface Props {
  class?: string;
}
const { class: cls = '' } = Astro.props;

let seed = 9176;
const rnd = () => {
  seed = (seed * 1103515245 + 12345) & 0x7fffffff;
  return seed / 0x7fffffff;
};
type Trend = 'rising' | 'flat' | 'falling';

const PAD = { l: 62, r: 702, t: 26, b: 372 };
const VW = 724;
const VH = 420;
const xPos = (p: number) => PAD.l + ((p - 1) / 79) * (PAD.r - PAD.l);
const yDem = (d: number) => PAD.t + (1 - (Math.log10(d) - 1) / 3) * (PAD.b - PAD.t);

const clusters = Array.from({ length: 40 }, () => {
  const pos = 2 + Math.floor(rnd() * 77);
  const demand = Math.round(10 * Math.pow(10, rnd() * 3)); // 10 → 10k, log-spread
  const t = rnd();
  const trend: Trend = t < 0.46 ? 'rising' : t < 0.72 ? 'flat' : 'falling';
  return { pos, demand, trend, r: 3 + Math.min(12, Math.sqrt(demand) / 8) };
});

// opportunity zone: rising demand (>=500) you rank weakly for (pos >= 13)
const zone = { x1: xPos(13), x2: xPos(80), y1: yDem(10000), y2: yDem(500) };
// the standout "losing share" cluster (falling, high demand, weak position)
const standout = { pos: 30, demand: 1600, label: '/pricing' };
const yTicks: { d: number; label: string }[] = [
  { d: 10, label: '10' },
  { d: 100, label: '100' },
  { d: 1000, label: '1k' },
  { d: 10000, label: '10k' },
];
const stats = [
  { v: '142', l: 'CLUSTERS' },
  { v: '77', l: 'RISING DEMAND' },
  { v: '72', l: 'LOSING SHARE' },
  { v: '104k', l: 'ADDR. DEMAND' },
];
---

<figure class={`scatter ${cls}`} role="img" aria-label="Demand and Trends: demand per month against your search position, on a log scale. Bubbles are clusters coloured by trend; a shaded zone marks rising demand you rank weakly for.">
  <header class="scatter__head">
    <div>
      <span class="scatter__title">Demand vs. your position</span>
      <span class="scatter__sub mono">geo UK · 142 clusters</span>
    </div>
    <div class="scatter__legend mono">
      <span><i class="dot dot--rising"></i>rising</span>
      <span><i class="dot dot--flat"></i>flat</span>
      <span><i class="dot dot--falling"></i>falling</span>
    </div>
  </header>

  <svg class="scatter__svg" viewBox={`0 0 ${VW} ${VH}`} preserveAspectRatio="xMidYMid meet">
    <!-- opportunity zone -->
    <rect
      x={zone.x1} y={zone.y1}
      width={zone.x2 - zone.x1} height={zone.y2 - zone.y1}
      class="scatter__zone"
    />
    <!-- y gridlines + labels -->
    {yTicks.map((t) => (
      <g>
        <line x1={PAD.l} y1={yDem(t.d)} x2={PAD.r} y2={yDem(t.d)} class="scatter__grid" />
        <text x={PAD.l - 8} y={yDem(t.d) + 3} class="scatter__ytick mono">{t.label}</text>
      </g>
    ))}
    <!-- bubbles -->
    <g class="scatter__pts">
      {clusters.map((c, i) => (
        <circle
          cx={xPos(c.pos)} cy={yDem(c.demand)} r={c.r}
          class={`pt pt--${c.trend}`}
          style={`--i:${i}`}
        />
      ))}
    </g>
    <!-- standout -->
    <circle cx={xPos(standout.pos)} cy={yDem(standout.demand)} r="9" class="pt pt--falling pt--standout" />
    <circle cx={xPos(standout.pos)} cy={yDem(standout.demand)} r="15" class="scatter__ring" />

    <!-- axis labels -->
    <text x={PAD.l} y={PAD.b + 26} class="scatter__axis mono">better ←</text>
    <text x={PAD.r} y={PAD.b + 26} class="scatter__axis scatter__axis--end mono">→ worse · your position</text>
    <text x={PAD.l - 8} y={PAD.t - 10} class="scatter__axis mono">demand/mo</text>
  </svg>

  <p class="scatter__zonenote mono">Shaded = rising demand you rank weakly for, your biggest opportunities</p>

  <dl class="scatter__stats">
    {stats.map((s) => (
      <div class="scatter__stat">
        <dt class="scatter__stat-v mono">{s.v}</dt>
        <dd class="scatter__stat-l mono">{s.l}</dd>
      </div>
    ))}
  </dl>

  <div class="scatter__callout mono" aria-hidden="true" style={`left:${(xPos(standout.pos) / VW) * 100}%; top:${(yDem(standout.demand) / VH) * 78}%`}>
    <span class="scatter__callout-tag">LOSING SHARE</span>
    <span class="scatter__callout-page">{standout.label}</span>
    <span class="scatter__callout-meta">demand ↑ · impr ↓ · 2 competing</span>
  </div>
</figure>

<style>
  .scatter {
    position: relative;
    margin: 0;
    font-size: var(--step--1);
    color: var(--ink);
  }
  .scatter__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-s);
    margin-bottom: var(--space-xs);
  }
  .scatter__title {
    display: block;
    font-weight: 600;
    font-size: var(--step-0);
    letter-spacing: -0.01em;
  }
  .scatter__sub {
    font-size: var(--step--2);
    color: var(--ink-faint);
  }
  .scatter__legend {
    display: flex;
    gap: 0.7rem;
    font-size: var(--step--2);
    color: var(--ink-dim);
  }
  .scatter__legend span {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
  }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    display: inline-block;
  }
  .dot--rising { background: var(--sev-emerald); }
  .dot--flat { background: var(--sev-flat); }
  .dot--falling { background: var(--sev-rose); }

  .scatter__svg {
    width: 100%;
    height: auto;
    overflow: visible;
  }
  .scatter__zone {
    fill: color-mix(in oklab, var(--sev-amber) 12%, transparent);
    stroke: color-mix(in oklab, var(--sev-amber) 35%, transparent);
    stroke-width: 1;
    stroke-dasharray: 3 4;
  }
  .scatter__grid {
    stroke: var(--hairline);
    stroke-width: 1;
  }
  .scatter__ytick {
    fill: var(--ink-faint);
    font-size: 11px;
    text-anchor: end;
  }
  .scatter__axis {
    fill: var(--ink-faint);
    font-size: 11px;
    letter-spacing: 0.04em;
  }
  .scatter__axis--end { text-anchor: end; }

  .pt {
    opacity: 0;
    animation: pop 0.45s var(--ease-out) forwards;
    animation-delay: calc(0.3s + var(--i, 0) * 0.014s);
  }
  @keyframes pop {
    from { opacity: 0; transform: scale(0.3); }
    to { opacity: 0.92; }
  }
  .pt--rising { fill: var(--sev-emerald); }
  .pt--flat { fill: var(--sev-flat); }
  .pt--falling { fill: var(--sev-rose); }
  .pt--standout {
    opacity: 1;
    animation: none;
    filter: drop-shadow(0 0 6px color-mix(in oklab, var(--sev-rose) 50%, transparent));
  }
  .scatter__ring {
    fill: none;
    stroke: var(--sev-rose);
    stroke-width: 1.4;
    transform-box: fill-box;
    transform-origin: center;
    animation: ring 2.6s var(--ease-out) infinite;
    animation-delay: 1.2s;
  }
  @keyframes ring {
    0% { opacity: 0.6; transform: scale(0.7); }
    70%, 100% { opacity: 0; transform: scale(1.8); }
  }

  .scatter__zonenote {
    margin-top: 0.3rem;
    font-size: var(--step--2);
    color: var(--ink-faint);
  }

  .scatter__stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    margin-top: var(--space-s);
    background: var(--hairline);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-s);
    overflow: hidden;
  }
  .scatter__stat {
    background: var(--surface-panel);
    padding: 0.5rem 0.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }
  .scatter__stat-v {
    font-size: var(--step-1);
    font-weight: 500;
    letter-spacing: -0.02em;
  }
  .scatter__stat-l {
    font-size: var(--step--2);
    color: var(--ink-faint);
    letter-spacing: 0.04em;
  }

  .scatter__callout {
    position: absolute;
    transform: translate(12px, -50%);
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    padding: 0.5rem 0.65rem;
    background: color-mix(in oklab, var(--surface-panel) 94%, transparent);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    border: 1px solid color-mix(in oklab, var(--sev-rose) 45%, var(--hairline));
    border-radius: var(--radius-s);
    box-shadow: var(--shadow-m);
    pointer-events: none;
  }
  .scatter__callout-tag {
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    color: var(--sev-rose);
  }
  .scatter__callout-page {
    font-size: 0.8rem;
    color: var(--ink);
  }
  .scatter__callout-meta {
    font-size: 0.55rem;
    color: var(--ink-dim);
  }

  @media (max-width: 560px) {
    .scatter__callout { display: none; }
    .scatter__legend { display: none; }
    .scatter__stats { grid-template-columns: repeat(2, 1fr); }
  }
  @media (prefers-reduced-motion: reduce) {
    .pt { opacity: 0.92; animation: none; }
    .scatter__ring { animation: none; }
  }
</style>
